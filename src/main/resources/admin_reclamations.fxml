<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1000.0"
            styleClass="page"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdminReclamationsController">

   <!-- Top Bar -->
   <top>
      <VBox>
         <!-- NAVBAR PRINCIPALE -->
         <HBox styleClass="sidebar" spacing="10" alignment="CENTER_LEFT">
            <padding>
               <Insets top="10" bottom="10" left="15" right="15" />
            </padding>

            <Label text="🏝️ VOYAGE &amp; SERVICES" styleClass="brand" />
            <Separator orientation="VERTICAL" />

            <Button text="📋 Gérer Réclamations" styleClass="nav-btn" onAction="#afficherAdminReclamations" />
            <Button text="⭐ Gérer Avis" styleClass="nav-btn" onAction="#afficherAdminAvis" />
            <Button text="📊 Statistiques" styleClass="nav-btn" onAction="#afficherStatistiques" />

            <Region HBox.hgrow="ALWAYS" />

            <Button text="👤 User Mode" onAction="#switchRole" styleClass="nav-btn"
                    style="-fx-background-color: #eadfc7; -fx-text-fill: #9a8a6f; -fx-font-weight: bold; -fx-border-color: #9a8a6f; -fx-border-radius: 10; -fx-background-radius: 10;" />
            <Button text="🚪 Déconnexion" styleClass="nav-btn-danger" onAction="#deconnexion" />
         </HBox>

         <!-- SOUS-BARRE TITRE -->
         <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="15">
            <padding>
               <Insets top="8" bottom="8" left="15" right="15" />
            </padding>
            <Label text="GESTION DES RÉCLAMATIONS" styleClass="pageTitle" />
         </HBox>
      </VBox>
   </top>

   <!-- Center Content -->
   <center>
      <VBox styleClass="pageContent" spacing="20">
         <padding>
            <Insets top="20" bottom="20" left="20" right="20" />
         </padding>

         <!-- Filters and Search -->
         <HBox spacing="15" alignment="CENTER_LEFT">
            <TextField fx:id="txtSearch" promptText="Rechercher (ID, Titre, Description...)" prefWidth="300" />
            <ComboBox fx:id="comboFilter" promptText="Tous les statuts" prefWidth="150" />
            <Button text="Réinitialiser" styleClass="btnOutline" onAction="#clearSearch" />
         </HBox>

         <!-- Table -->
         <TableView fx:id="tableReclamations" styleClass="table-view" VBox.vgrow="ALWAYS">
            <columns>
               <TableColumn fx:id="colId" text="ID" prefWidth="60" />
               <TableColumn fx:id="colUser" text="User ID" prefWidth="80" />
               <TableColumn fx:id="colTitre" text="Titre" prefWidth="180" />
               <TableColumn fx:id="colDescription" text="Description" prefWidth="250" />
               <TableColumn fx:id="colStatut" text="Statut" prefWidth="120" />
               <TableColumn fx:id="colReponse" text="Réponse" prefWidth="200" />
               <TableColumn fx:id="colDateReponse" text="Date réponse" prefWidth="150" />
               <TableColumn fx:id="colActions" text="Actions" prefWidth="150" />
            </columns>
         </TableView>

         <!-- Response Area -->
         <VBox styleClass="card" spacing="15">
            <Label text="RÉPONDRE À LA RÉCLAMATION SÉLECTIONNÉE" styleClass="cardTitle" />
            <TextArea fx:id="txtReponse"
                      promptText="Saisissez votre réponse ici..."
                      prefHeight="100"
                      wrapText="true" />
            <HBox alignment="CENTER_RIGHT">
               <Button fx:id="btnSubmit"
                       text="Envoyer la réponse"
                       styleClass="btnGreen"
                       onAction="#validerReponse" />
            </HBox>
         </VBox>

      </VBox>
   </center>

</BorderPane>