<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1400.0" 
            styleClass="page"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controllers.UserLayoutController">
   
   <!-- SIDEBAR GAUCHE -->
   <left>
      <VBox styleClass="sidebar" prefWidth="240" spacing="5">
         
         <!-- LOGO / BRAND -->
         <VBox spacing="3" styleClass="sidebarHeader">
            <padding>
               <Insets top="20" bottom="20" left="15" right="15" />
            </padding>
            <Label text="🏝️ VOYAGE USER" styleClass="brand" />
            <Label text="Espace Client" 
                   style="-fx-font-size: 11px; -fx-text-fill: #6a7a73; -fx-font-weight: 600;" />
         </VBox>
         
         <Separator styleClass="hr" />
         
         <!-- ========== SECTION MES SERVICES ========== -->
         <VBox spacing="3">
            <padding>
               <Insets top="15" bottom="5" left="15" right="15" />
            </padding>
            
            <Label text="MES SERVICES" 
                   style="-fx-font-size: 10px; -fx-text-fill: #9a8a6f; -fx-font-weight: 900; -fx-padding: 0 0 8 0;" />
            
            <Button text="📋 Mes Réclamations" 
                    styleClass="nav-btn" 
                    prefWidth="210"
                    alignment="CENTER_LEFT"
                    onAction="#afficherMesReclamations" />
            
            <Button text="⭐ Mes Avis" 
                    styleClass="nav-btn" 
                    prefWidth="210"
                    alignment="CENTER_LEFT"
                    onAction="#afficherMesAvis" />
            
            <Button text="👁️ Avis Publics" 
                    styleClass="nav-btn" 
                    prefWidth="210"
                    alignment="CENTER_LEFT"
                    onAction="#afficherAvisPublics" />
         </VBox>
         
         <!-- SPACER -->
         <Region VBox.vgrow="ALWAYS" />
         
         <Separator styleClass="hr" />
         
         <!-- ========== SECTION BAS ========== -->
         <VBox spacing="3">
            <padding>
               <Insets top="10" bottom="20" left="15" right="15" />
            </padding>
            
            <Button text="👤 Admin Mode" 
                    onAction="#switchRole"
                    styleClass="nav-btn" 
                    prefWidth="210"
                    style="-fx-background-color: #eadfc7; -fx-text-fill: #9a8a6f; -fx-font-weight: bold; -fx-border-color: #9a8a6f; -fx-border-radius: 10; -fx-background-radius: 10;" />
            
            <Button text="🚪 Déconnexion" 
                    styleClass="nav-btn-danger" 
                    prefWidth="210"
                    alignment="CENTER_LEFT"
                    onAction="#deconnexion" />
         </VBox>
         
      </VBox>
   </left>
   
   <!-- CONTENU PRINCIPAL -->
   <center>
      <StackPane fx:id="contentArea" styleClass="pageContent">
         <!-- Le contenu sera chargé ici dynamiquement -->
      </StackPane>
   </center>
   
</BorderPane>
