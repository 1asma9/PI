<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="400" prefHeight="600" 
      styleClass="card"
      spacing="15"
      xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controllers.ChatbotController">
   
   <!-- En-tête -->
   <HBox alignment="CENTER_LEFT" spacing="12">
      <Label text="🤖" style="-fx-font-size: 28px;" />
      <VBox spacing="3" HBox.hgrow="ALWAYS">
         <Label fx:id="lblTitreChatbot" text="Assistant Réclamations" styleClass="cardTitle" />
         <Label text="Posez vos questions, je vous aide !" styleClass="metaText" />
      </VBox>
      <Button text="↻" 
              styleClass="iconBtn, btnOutline" 
              onAction="#reinitialiser"
              style="-fx-font-size: 16px;" />
   </HBox>
   
   <Separator styleClass="hr" />
   
   <!-- Zone de chat -->
   <ScrollPane fx:id="scrollPane" 
               styleClass="scroll-pane" 
               fitToWidth="true" 
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #fbf7f1; -fx-background-radius: 12;">
      <VBox fx:id="chatContainer" 
            spacing="12" 
            style="-fx-background-color: #fbf7f1; -fx-background-radius: 12;">
         <padding>
            <Insets bottom="15" left="15" right="15" top="15" />
         </padding>
         <!-- Messages du chat seront ajoutés ici dynamiquement -->
      </VBox>
   </ScrollPane>
   
   <!-- Zone de saisie -->
   <HBox spacing="10" alignment="CENTER">
      <TextField fx:id="txtMessage" 
                 promptText="Tapez votre message..." 
                 HBox.hgrow="ALWAYS"
                 onAction="#envoyerMessage" />
      
      <Button text="➤" 
              styleClass="btnGold"
              prefWidth="50"
              prefHeight="40"
              style="-fx-font-size: 18px;"
              onAction="#envoyerMessage" />
   </HBox>
   
</VBox>
