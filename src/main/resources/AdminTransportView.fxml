<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.destination.controllers.AdminTransportController"
      stylesheets="@/app/transport.css"
      styleClass="page" spacing="16">

    <Label text="Gestion des Transports" styleClass="pageTitle"/>

    <VBox styleClass="glass-card-large" spacing="14">
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 20 10 20;">
            <ComboBox fx:id="comboTypeTransport"
                      promptText="Type de transport"
                      prefWidth="200"/>
            <TextField fx:id="searchVoyageId"
                       promptText="ID Voyage..."
                       prefWidth="180"
                       styleClass="input-field"/>
            <Button fx:id="btnReset" text="Reset" styleClass="btn-secondary"/>
        </HBox>

        <!-- ✅ prefHeight réduit pour que les boutons soient visibles -->
        <TableView fx:id="tableTransports" prefHeight="350" styleClass="table-modern">
            <columns>
                <TableColumn fx:id="colIdTransport" text="ID" prefWidth="70"/>
                <TableColumn fx:id="colTypeTransport" text="Type" prefWidth="150"/>
                <TableColumn fx:id="colVoyageId" text="Voyage ID" prefWidth="200"/>
            </columns>
        </TableView>

        <HBox spacing="14" alignment="CENTER" style="-fx-padding: 10 0 10 0;">
            <Button fx:id="btnAjouter" text="Ajouter" styleClass="btn-primary"/>
            <Button fx:id="btnModifier" text="Modifier" styleClass="btn-warning"/>
            <Button fx:id="btnSupprimer" text="Supprimer" styleClass="btn-danger"/>
        </HBox>
    </VBox>

</VBox>
