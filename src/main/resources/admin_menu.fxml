<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="800.0" 
            styleClass="page"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controllers.AdminMenuController">
   
   <!-- Top Bar -->
   <top>
      <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="15">
         <Button text="← Retour" styleClass="btnOutline" onAction="#retourMenu" />
         <Label text="ESPACE ADMIN" styleClass="pageTitle" />
      </HBox>
   </top>
   
   <!-- Center Content -->
   <center>
      <VBox alignment="CENTER" spacing="30" styleClass="pageContent">
         <HBox alignment="CENTER" spacing="30">
            <!-- Card Réclamations -->
            <VBox styleClass="card" alignment="CENTER" spacing="15" 
                  prefWidth="250" prefHeight="220" onMouseClicked="#goToReclamationsClick">
               <Label text="📋" style="-fx-font-size: 40px;" />
               <Label text="RÉCLAMATIONS" styleClass="cardTitle" />
               <Label text="Gérer les réclamations" styleClass="metaText" />
               <Button text="Accéder" styleClass="btnGreen" onAction="#goToReclamations" />
            </VBox>
            
            <!-- Card Avis -->
            <VBox styleClass="card" alignment="CENTER" spacing="15" 
                  prefWidth="250" prefHeight="220" onMouseClicked="#goToAvisClick">
               <Label text="⭐" style="-fx-font-size: 40px;" />
               <Label text="AVIS" styleClass="cardTitle" />
               <Label text="Gérer les avis" styleClass="metaText" />
               <Button text="Accéder" styleClass="btnGreen" onAction="#goToAvis" />
            </VBox>
         </HBox>
         
         <!-- Card Statistiques -->
         <VBox styleClass="card" alignment="CENTER" spacing="15" 
               prefWidth="530" prefHeight="150" onMouseClicked="#goToStatisticsClick">
            <HBox alignment="CENTER" spacing="20">
               <Label text="📊" style="-fx-font-size: 40px;" />
               <VBox alignment="CENTER_LEFT">
                  <Label text="STATISTIQUES" styleClass="cardTitle" />
                  <Label text="Voir les analyses de performance" styleClass="metaText" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Button text="Consulter" styleClass="btnGreen" onAction="#goToStatistics" />
            </HBox>
         </VBox>
      </VBox>
   </center>
   
</BorderPane>
