<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.destination.controllers.ClientDetailsController"
            style="-fx-background-color: #f7f5f1;">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #0d0e12;
                     -fx-padding: 14 44 14 44;">
            <Button fx:id="btnBackToList" text="← Destinations"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: rgba(255,255,255,0.55);
                           -fx-font-size: 12px; -fx-font-weight: 600;
                           -fx-border-color: rgba(255,255,255,0.15);
                           -fx-border-radius: 6; -fx-background-radius: 6;
                           -fx-border-width: 1; -fx-padding: 8 18 8 18;
                           -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="—" style="-fx-text-fill: #c8956c; -fx-font-size: 12px;"/>
                <Label text="VOYAGELOISIR"
                       style="-fx-text-fill: #c8956c; -fx-font-size: 10px; -fx-font-weight: 700;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: rgba(126,201,154,0.12);
                         -fx-border-color: rgba(126,201,154,0.3); -fx-border-radius: 6;
                         -fx-background-radius: 6; -fx-border-width: 1;
                         -fx-padding: 7 18 7 18;">
                <Label text="●" style="-fx-text-fill: #7ec99a; -fx-font-size: 8px;"/>
                <Label text="Disponible"
                       style="-fx-text-fill: #7ec99a; -fx-font-size: 11px; -fx-font-weight: 700;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: #f7f5f1; -fx-background-color: #f7f5f1;
                           -fx-border-color: transparent;">
            <VBox spacing="0" style="-fx-background-color: #f7f5f1;">

                <!-- ===== HERO SLIDER ===== -->
                <StackPane minHeight="620" prefHeight="650">
                    <ImageView fx:id="imageView" fitWidth="1400" fitHeight="650"
                               preserveRatio="false" smooth="true"/>

                    <!-- Veil gauche -->
                    <Pane style="-fx-background-color: linear-gradient(to right,
                                     rgba(10,9,8,0.92) 0%, rgba(10,9,8,0.55) 45%,
                                     rgba(10,9,8,0.18) 100%);"/>
                    <!-- Veil bas -->
                    <Pane style="-fx-background-color: linear-gradient(to top,
                                     rgba(247,245,241,1.0) 0%, rgba(247,245,241,0.5) 16%,
                                     transparent 40%);"/>

                    <!-- Contenu hero -->
                    <VBox alignment="BOTTOM_LEFT" prefHeight="650"
                          style="-fx-padding: 0 80 64 80;">

                        <!-- Breadcrumb -->
                        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 20 0;">
                            <Label text="Accueil"
                                   style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 10px;
                                          -fx-font-weight: 600;"/>
                            <Label text="—" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 10px;"/>
                            <Label text="Destinations"
                                   style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 10px;
                                          -fx-font-weight: 600;"/>
                            <Label text="—" style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 10px;"/>
                            <Label fx:id="lblBreadcrumb"
                                   style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10px;
                                          -fx-font-weight: 600;"/>
                        </HBox>

                        <!-- Tag pays -->
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 18 0;">
                            <HBox spacing="8" alignment="CENTER_LEFT"
                                  style="-fx-background-color: rgba(200,149,108,0.15);
                                         -fx-border-color: rgba(200,149,108,0.3);
                                         -fx-border-radius: 30; -fx-background-radius: 30;
                                         -fx-border-width: 1; -fx-padding: 6 16 6 16;">
                                <Label style="-fx-background-color: #c8956c;
                                              -fx-min-width: 5; -fx-min-height: 5;
                                              -fx-background-radius: 50%;"/>
                                <Label fx:id="lblCountryTag"
                                       style="-fx-text-fill: #c8956c; -fx-font-size: 11px;
                                              -fx-font-weight: 600;"/>
                            </HBox>
                        </HBox>

                        <!-- Titre -->
                        <Label fx:id="lblName"
                               style="-fx-text-fill: white; -fx-font-size: 88px;
                                      -fx-font-weight: 300; -fx-font-family: 'Georgia';
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 0, 4);"/>

                        <Region prefHeight="24"/>

                        <!-- Description courte -->
                        <Label fx:id="lblDescShort" wrapText="true" maxWidth="500"
                               style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 14px;
                                      -fx-font-weight: 300; -fx-line-spacing: 4;
                                      -fx-padding: 0 0 32 0;"/>

                        <!-- Meta stats + navigation -->
                        <HBox spacing="0" alignment="CENTER_LEFT">
                            <!-- Stats -->
                            <HBox spacing="0" alignment="CENTER_LEFT">
                                <VBox spacing="4" style="-fx-padding: 0 28 0 0;">
                                    <Label fx:id="lblVisits"
                                           style="-fx-text-fill: white; -fx-font-size: 22px;
                                                  -fx-font-weight: 500; -fx-font-family: Georgia;"/>
                                    <Label text="VISITES"
                                           style="-fx-text-fill: rgba(255,255,255,0.35);
                                                  -fx-font-size: 9px; -fx-font-weight: 700;"/>
                                </VBox>
                                <Pane prefWidth="1" prefHeight="36"
                                      style="-fx-background-color: rgba(255,255,255,0.12);"/>
                                <VBox spacing="4" style="-fx-padding: 0 28 0 28;">
                                    <Label fx:id="lblLikesHero"
                                           style="-fx-text-fill: #c8956c; -fx-font-size: 22px;
                                                  -fx-font-weight: 500; -fx-font-family: Georgia;"/>
                                    <Label text="J'AIME"
                                           style="-fx-text-fill: rgba(255,255,255,0.35);
                                                  -fx-font-size: 9px; -fx-font-weight: 700;"/>
                                </VBox>
                                <Pane prefWidth="1" prefHeight="36"
                                      style="-fx-background-color: rgba(255,255,255,0.12);"/>
                                <VBox spacing="4" style="-fx-padding: 0 28 0 28;">
                                    <Label fx:id="lblSaison"
                                           style="-fx-text-fill: white; -fx-font-size: 22px;
                                                  -fx-font-weight: 500; -fx-font-family: Georgia;"/>
                                    <Label text="SAISON"
                                           style="-fx-text-fill: rgba(255,255,255,0.35);
                                                  -fx-font-size: 9px; -fx-font-weight: 700;"/>
                                </VBox>
                            </HBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <!-- Note étoiles -->
                            <VBox spacing="8" alignment="CENTER_RIGHT">
                                <Label fx:id="lblScoreNum"
                                       style="-fx-text-fill: white; -fx-font-size: 72px;
                                              -fx-font-weight: 300; -fx-font-family: Georgia;"/>
                                <Label text="/ 5 · Note globale"
                                       style="-fx-text-fill: rgba(255,255,255,0.3);
                                              -fx-font-size: 10px;"/>
                                <HBox fx:id="starsContainer" spacing="4" alignment="CENTER_RIGHT"/>
                            </VBox>

                            <!-- Navigation images -->
                            <HBox spacing="0" alignment="CENTER"
                                  style="-fx-background-color: rgba(255,255,255,0.1);
                                         -fx-border-color: rgba(255,255,255,0.2);
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-border-width: 1;">
                                <HBox.margin><Insets left="24"/></HBox.margin>
                                <Button fx:id="btnPrev" text="←"
                                        style="-fx-background-color: transparent;
                                               -fx-text-fill: rgba(255,255,255,0.65);
                                               -fx-font-size: 16px; -fx-font-weight: 700;
                                               -fx-padding: 12 22 12 22; -fx-cursor: hand;"/>
                                <Pane prefWidth="1" prefHeight="20"
                                      style="-fx-background-color: rgba(255,255,255,0.2);"/>
                                <Button fx:id="btnNext" text="→"
                                        style="-fx-background-color: transparent;
                                               -fx-text-fill: white;
                                               -fx-font-size: 16px; -fx-font-weight: 700;
                                               -fx-padding: 12 22 12 22; -fx-cursor: hand;"/>
                            </HBox>
                        </HBox>
                    </VBox>

                    <!-- Dots slider -->
                    <HBox fx:id="dotsContainer" spacing="8" alignment="BOTTOM_CENTER"
                          style="-fx-padding: 0 0 28 0;"
                          StackPane.alignment="BOTTOM_CENTER"/>
                </StackPane>

                <!-- ===== BARRE TRADUCTION ===== -->
                <HBox spacing="16" alignment="CENTER_LEFT"
                      style="-fx-background-color: rgba(247,245,241,0.95);
                             -fx-border-color: #eceae5; -fx-border-width: 0 0 1 0;
                             -fx-padding: 10 80 10 80;">
                    <Label text="🌍" style="-fx-font-size: 14px;"/>
                    <Label text="Langue :"
                           style="-fx-text-fill: #8a8880; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                    <Button text="🇫🇷 Français" fx:id="btnLangFr"
                            style="-fx-background-color: #c8956c; -fx-text-fill: white;
                                   -fx-font-size: 11px; -fx-font-weight: 600;
                                   -fx-background-radius: 20; -fx-padding: 5 14 5 14; -fx-cursor: hand;"/>
                    <Button text="🇬🇧 English" fx:id="btnLangEn"
                            style="-fx-background-color: #f5f2ec;
                                   -fx-border-color: #e8e4dc; -fx-border-radius: 20;
                                   -fx-background-radius: 20; -fx-border-width: 1;
                                   -fx-text-fill: #7a7670; -fx-font-size: 11px; -fx-font-weight: 600;
                                   -fx-padding: 5 14 5 14; -fx-cursor: hand;"/>
                    <Button text="🇸🇦 العربية" fx:id="btnLangAr"
                            style="-fx-background-color: #f5f2ec;
                                   -fx-border-color: #e8e4dc; -fx-border-radius: 20;
                                   -fx-background-radius: 20; -fx-border-width: 1;
                                   -fx-text-fill: #7a7670; -fx-font-size: 11px; -fx-font-weight: 600;
                                   -fx-padding: 5 14 5 14; -fx-cursor: hand;"/>
                    <Label fx:id="lblTranslating" text=""
                           style="-fx-text-fill: #c8956c; -fx-font-size: 11px;"/>
                </HBox>

                <!-- ===== LAYOUT PRINCIPAL 2 COLONNES ===== -->
                <HBox spacing="32"
                      style="-fx-padding: 48 80 0 80; -fx-background-color: #f7f5f1;">

                    <!-- COLONNE GAUCHE -->
                    <VBox spacing="24" HBox.hgrow="ALWAYS">

                        <!-- À PROPOS -->
                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 20;
                                     -fx-border-color: #eeece8; -fx-border-radius: 20; -fx-border-width: 1;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding: 22 28 22 28;
                                         -fx-border-color: #eeece8; -fx-border-width: 0 0 1 0;">
                                <Label text="À PROPOS"
                                       style="-fx-text-fill: #c8956c; -fx-font-size: 10px;
                                              -fx-font-weight: 700;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="✦" style="-fx-text-fill: #d4a855; -fx-font-size: 11px;"/>
                            </HBox>
                            <VBox spacing="12" style="-fx-padding: 28 32 28 32;">
                                <Label fx:id="lblDestTitle"
                                       style="-fx-text-fill: #1a1814; -fx-font-size: 26px;
                                              -fx-font-weight: 400; -fx-font-family: Georgia;"/>
                                <Pane prefWidth="40" prefHeight="1"
                                      style="-fx-background-color: #c8956c; -fx-opacity: 0.5;"/>
                                <Label fx:id="lblDescription" wrapText="true"
                                       style="-fx-text-fill: #8a8880; -fx-font-size: 14px;
                                              -fx-font-weight: 300; -fx-line-spacing: 6;"/>
                            </VBox>
                        </VBox>

                        <!-- ITINÉRAIRE IA -->
                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 20;
                                     -fx-border-color: #eeece8; -fx-border-radius: 20; -fx-border-width: 1;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding: 22 28 22 28;
                                         -fx-border-color: #eeece8; -fx-border-width: 0 0 1 0;">
                                <VBox spacing="3">
                                    <Label text="INTELLIGENCE ARTIFICIELLE"
                                           style="-fx-text-fill: #c8956c; -fx-font-size: 10px;
                                                  -fx-font-weight: 700;"/>
                                    <Label text="Programme de voyage"
                                           style="-fx-text-fill: #1a1814; -fx-font-size: 20px;
                                                  -fx-font-weight: 400; -fx-font-family: Georgia;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblItinLoading" text=""
                                       style="-fx-text-fill: #c8956c; -fx-font-size: 12px;"/>
                            </HBox>
                            <VBox spacing="16" style="-fx-padding: 24 32 24 32;">
                                <Label text="Choisissez la durée — l'IA génère votre programme complet jour par jour."
                                       style="-fx-text-fill: #8a8880; -fx-font-size: 13px; -fx-font-weight: 300;"/>
                                <HBox fx:id="itinBtnsContainer" spacing="10" alignment="CENTER_LEFT"/>
                                <VBox fx:id="itinResultContainer" spacing="0"
                                      visible="false" managed="false"/>
                            </VBox>
                        </VBox>

                        <!-- CARTE LEAFLET -->
                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 20;
                                     -fx-border-color: #eeece8; -fx-border-radius: 20; -fx-border-width: 1;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding: 22 28 22 28;
                                         -fx-border-color: #eeece8; -fx-border-width: 0 0 1 0;">
                                <VBox spacing="3">
                                    <Label text="LOCALISATION"
                                           style="-fx-text-fill: #c8956c; -fx-font-size: 10px;
                                                  -fx-font-weight: 700;"/>
                                    <Label text="Carte &amp; Trajets"
                                           style="-fx-text-fill: #1a1814; -fx-font-size: 20px;
                                                  -fx-font-weight: 400; -fx-font-family: Georgia;"/>
                                </VBox>
                            </HBox>
                            <!-- Boutons sélection voyage -->
                            <HBox fx:id="mapVoyageBtns" spacing="8" alignment="CENTER_LEFT"
                                  style="-fx-padding: 14 28 0 28;"/>
                            <BorderPane fx:id="mapPane" prefHeight="360"
                                        style="-fx-background-color: #e8e4dc;"/>
                            <!-- Info trajet -->
                            <HBox fx:id="routeInfoBox" alignment="CENTER_LEFT"
                                  style="-fx-padding: 14 28 22 28; -fx-background-color: #f9f8f5;
                                         -fx-background-radius: 0 0 20 20;
                                         -fx-border-color: #eeece8; -fx-border-width: 1 0 0 0;">
                                <Label fx:id="lblRouteInfo" wrapText="true"
                                       style="-fx-text-fill: #5a5450; -fx-font-size: 13px;"/>
                            </HBox>
                        </VBox>

                        <!-- MÉTÉO -->
                        <VBox fx:id="weatherBox" spacing="0" visible="false" managed="false"
                              style="-fx-background-color: white; -fx-background-radius: 20;
                                     -fx-border-color: #eeece8; -fx-border-radius: 20; -fx-border-width: 1;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding: 18 24 18 24;
                                         -fx-border-color: #eeece8; -fx-border-width: 0 0 1 0;">
                                <VBox spacing="2">
                                    <Label text="MÉTÉO EN TEMPS RÉEL"
                                           style="-fx-text-fill: #c8956c; -fx-font-size: 10px;
                                                  -fx-font-weight: 700;"/>
                                    <Label fx:id="lblWeatherCity"
                                           style="-fx-text-fill: #1a1814; -fx-font-size: 18px;
                                                  -fx-font-weight: 400; -fx-font-family: Georgia;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="🌤" style="-fx-font-size: 20px;"/>
                            </HBox>

                            <!-- Temp principale -->
                            <HBox spacing="16" alignment="CENTER_LEFT"
                                  style="-fx-padding: 20 24 16 24;">
                                <VBox spacing="0" alignment="CENTER"
                                      style="-fx-background-color: #2c4a6e;
                                             -fx-background-radius: 14;
                                             -fx-min-width: 110; -fx-max-width: 110;
                                             -fx-padding: 22 16 18 16;">
                                    <Label fx:id="lblWeatherTemp"
                                           style="-fx-text-fill: white; -fx-font-size: 44px;
                                                  -fx-font-weight: 900; -fx-font-family: Georgia;"/>
                                    <Label fx:id="lblWeatherDesc"
                                           style="-fx-text-fill: rgba(255,255,255,0.6);
                                                  -fx-font-size: 10px; -fx-font-weight: 600;
                                                  -fx-padding: 4 0 0 0;"/>
                                </VBox>
                                <VBox spacing="12" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <Label text="🌡" style="-fx-font-size: 12px;"/>
                                        <Label text="RESSENTI"
                                               style="-fx-text-fill: #a8a4a0; -fx-font-size: 9px; -fx-font-weight: 700;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="lblWeatherFeels"
                                               style="-fx-text-fill: #1a1814; -fx-font-size: 13px; -fx-font-weight: 700;"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <Label text="💧" style="-fx-font-size: 12px;"/>
                                        <Label text="HUMIDITÉ"
                                               style="-fx-text-fill: #a8a4a0; -fx-font-size: 9px; -fx-font-weight: 700;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="lblWeatherHumidity"
                                               style="-fx-text-fill: #1a1814; -fx-font-size: 13px; -fx-font-weight: 700;"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <Label text="💨" style="-fx-font-size: 12px;"/>
                                        <Label text="VENT"
                                               style="-fx-text-fill: #a8a4a0; -fx-font-size: 9px; -fx-font-weight: 700;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="lblWeatherWind"
                                               style="-fx-text-fill: #1a1814; -fx-font-size: 13px; -fx-font-weight: 700;"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="6"
                                          style="-fx-background-color: #f9f8f5;
                                                 -fx-background-radius: 8; -fx-border-color: #eeece8;
                                                 -fx-border-radius: 8; -fx-border-width: 1;
                                                 -fx-padding: 10 14 10 14;">
                                        <Label text="INDICE VOYAGE"
                                               style="-fx-text-fill: #a8a4a0; -fx-font-size: 9px; -fx-font-weight: 700;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="lblWeatherIndex"
                                               style="-fx-font-size: 12px; -fx-font-weight: 800;"/>
                                    </HBox>
                                </VBox>
                            </HBox>

                            <!-- Prévisions 5 jours -->
                            <VBox spacing="10" style="-fx-padding: 0 24 20 24;
                                                       -fx-border-color: #eeece8; -fx-border-width: 1 0 0 0;">
                                <Label text="PRÉVISIONS 5 JOURS"
                                       style="-fx-text-fill: #a8a4a0; -fx-font-size: 10px;
                                              -fx-font-weight: 700;
                                              -fx-padding: 16 0 4 0;"/>
                                <HBox fx:id="forecastContainer" spacing="8" alignment="CENTER_LEFT"/>
                            </VBox>
                        </VBox>

                        <!-- VIDÉO LOCALE -->
                        <VBox fx:id="videoSection" spacing="0" visible="false" managed="false"
                              style="-fx-background-color: #0f0d0a; -fx-background-radius: 20;
                                     -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 20;
                                     -fx-border-width: 1;">
                            <HBox alignment="CENTER_LEFT" spacing="14"
                                  style="-fx-background-color: #1a150f; -fx-padding: 16 28 16 28;
                                         -fx-background-radius: 20 20 0 0;
                                         -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 0 1 0;">
                                <Label text="▶" style="-fx-text-fill: #d4a855; -fx-font-size: 11px;"/>
                                <Label fx:id="lblVideoTitle" text="Vidéo promotionnelle"
                                       style="-fx-text-fill: rgba(255,255,255,0.6);
                                              -fx-font-size: 13px; -fx-font-weight: 600;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="btnCloseVideo" text="✕  Fermer"
                                        onAction="#handleCloseVideo"
                                        style="-fx-background-color: rgba(255,255,255,0.06);
                                               -fx-text-fill: rgba(255,255,255,0.4);
                                               -fx-font-weight: 600; -fx-font-size: 11px;
                                               -fx-border-color: rgba(255,255,255,0.1);
                                               -fx-border-radius: 6; -fx-background-radius: 6;
                                               -fx-border-width: 1; -fx-padding: 7 16 7 16; -fx-cursor: hand;"/>
                            </HBox>
                            <StackPane fx:id="videoContainer" minHeight="400" prefHeight="420"
                                       alignment="CENTER"
                                       style="-fx-background-color: #050402;">
                                <VBox fx:id="videoLoadingPane" alignment="CENTER" spacing="16">
                                    <ProgressIndicator prefWidth="44" prefHeight="44"
                                                       style="-fx-accent: #d4a855;"/>
                                    <Label text="Chargement..."
                                           style="-fx-text-fill: rgba(255,255,255,0.2);
                                                  -fx-font-size: 11px;"/>
                                </VBox>
                                <VBox fx:id="videoErrorPane" alignment="CENTER" spacing="14"
                                      visible="false" managed="false">
                                    <Label text="⚠" style="-fx-text-fill: #d4a855; -fx-font-size: 36px;"/>
                                    <Label fx:id="lblVideoError" text="Vidéo introuvable" wrapText="true"
                                           style="-fx-text-fill: rgba(255,255,255,0.3);
                                                  -fx-font-size: 13px;"/>
                                </VBox>
                            </StackPane>
                            <HBox fx:id="videoControls" alignment="CENTER_LEFT" spacing="12"
                                  visible="false" managed="false"
                                  style="-fx-background-color: #1a150f; -fx-padding: 14 24 14 24;
                                         -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 1 0 0 0;">
                                <Button fx:id="btnPlayPause" text="⏸  Pause"
                                        onAction="#handlePlayPause"
                                        style="-fx-background-color: #d4a855; -fx-text-fill: #1a150f;
                                               -fx-font-size: 12px; -fx-font-weight: 800;
                                               -fx-background-radius: 6; -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>
                                <Button fx:id="btnStop" text="⏹  Stop" onAction="#handleStop"
                                        style="-fx-background-color: rgba(255,255,255,0.06);
                                               -fx-text-fill: rgba(255,255,255,0.45);
                                               -fx-font-size: 12px; -fx-font-weight: 600;
                                               -fx-background-radius: 6;
                                               -fx-border-color: rgba(255,255,255,0.1);
                                               -fx-border-radius: 6; -fx-border-width: 1;
                                               -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>
                                <Slider fx:id="timeSlider" min="0" max="100" value="0"
                                        HBox.hgrow="ALWAYS" style="-fx-accent: #d4a855;"/>
                                <Label fx:id="lblVideoTime" text="0:00 / 0:00"
                                       style="-fx-text-fill: rgba(255,255,255,0.22); -fx-font-size: 11px;"/>
                                <Label text="🔊"
                                       style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.3);"/>
                                <Slider fx:id="volumeSlider" min="0" max="1" value="1.0"
                                        prefWidth="80" style="-fx-accent: #d4a855;"/>
                            </HBox>
                        </VBox>

                    </VBox>

                    <!-- COLONNE DROITE (SIDEBAR) -->
                    <VBox spacing="20" minWidth="360" maxWidth="400">

                        <!-- STATS GRID -->
                        <HBox spacing="12">
                            <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 14; -fx-border-color: #eeece8;
                                         -fx-border-radius: 14; -fx-border-width: 1;
                                         -fx-padding: 20 16 20 16;">
                                <Label fx:id="lblCountry"
                                       style="-fx-text-fill: #1a1814; -fx-font-size: 15px; -fx-font-weight: 600;"/>
                                <Label text="PAYS"
                                       style="-fx-text-fill: #a8a4a0; -fx-font-size: 9px;
                                              -fx-font-weight: 700;"/>
                            </VBox>
                            <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 14; -fx-border-color: #eeece8;
                                         -fx-border-radius: 14; -fx-border-width: 1;
                                         -fx-padding: 20 16 20 16;">
                                <Label fx:id="lblStatSaison"
                                       style="-fx-text-fill: #c8956c; -fx-font-size: 15px; -fx-font-weight: 600;"/>
                                <Label text="SAISON"
                                       style="-fx-text-fill: #a8a4a0; -fx-font-size: 9px;
                                              -fx-font-weight: 700;"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="12">
                            <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 14; -fx-border-color: #eeece8;
                                         -fx-border-radius: 14; -fx-border-width: 1;
                                         -fx-padding: 20 16 20 16;">
                                <Label fx:id="lblStatVisits"
                                       style="-fx-text-fill: #1a1814; -fx-font-size: 24px;
                                              -fx-font-weight: 300; -fx-font-family: Georgia;"/>
                                <Label text="VISITES"
                                       style="-fx-text-fill: #a8a4a0; -fx-font-size: 9px;
                                              -fx-font-weight: 700;"/>
                            </VBox>
                            <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white;
                                         -fx-background-radius: 14; -fx-border-color: #eeece8;
                                         -fx-border-radius: 14; -fx-border-width: 1;
                                         -fx-padding: 20 16 20 16;">
                                <Label fx:id="lblStatLikes"
                                       style="-fx-text-fill: #e74c3c; -fx-font-size: 24px;
                                              -fx-font-weight: 300; -fx-font-family: Georgia;"/>
                                <Label text="J'AIME"
                                       style="-fx-text-fill: #a8a4a0; -fx-font-size: 9px;
                                              -fx-font-weight: 700;"/>
                            </VBox>
                        </HBox>

                        <!-- VOYAGES / TICKETS -->
                        <VBox spacing="0"
                              style="-fx-background-color: white; -fx-background-radius: 20;
                                     -fx-border-color: #eeece8; -fx-border-radius: 20; -fx-border-width: 1;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding: 18 24 18 24;
                                         -fx-border-color: #eeece8; -fx-border-width: 0 0 1 0;">
                                <VBox spacing="2">
                                    <Label text="OFFRES DISPONIBLES"
                                           style="-fx-text-fill: #c8956c; -fx-font-size: 10px;
                                                  -fx-font-weight: 700;"/>
                                    <Label text="Voyages"
                                           style="-fx-text-fill: #1a1814; -fx-font-size: 20px;
                                                  -fx-font-weight: 400; -fx-font-family: Georgia;"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblVoyageCount"
                                       style="-fx-background-color: rgba(200,149,108,0.12);
                                              -fx-text-fill: #c8956c;
                                              -fx-border-color: rgba(200,149,108,0.3);
                                              -fx-border-radius: 20; -fx-background-radius: 20;
                                              -fx-border-width: 1; -fx-padding: 4 14 4 14;
                                              -fx-font-size: 12px; -fx-font-weight: 500;"/>
                            </HBox>
                            <VBox fx:id="voyagesContainer" spacing="0"
                                  style="-fx-padding: 16 0 16 0;"/>
                        </VBox>

                        <!-- BOUTON VIDÉO -->
                        <Button fx:id="btnWatchVideo"
                                text="▶  Regarder la vidéo promotionnelle"
                                onAction="#handleWatchVideo"
                                visible="false" managed="false"
                                maxWidth="Infinity"
                                style="-fx-background-color: #1a1814;
                                       -fx-text-fill: #f7f5f1;
                                       -fx-font-size: 13px; -fx-font-weight: 700;
                                       -fx-background-radius: 12;
                                       -fx-padding: 16 0 16 0; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(26,24,20,0.3), 14, 0, 0, 5);"/>

                    </VBox>
                </HBox>

                <!-- ===== GALERIE PLEIN ÉCRAN ===== -->
                <VBox spacing="0" style="-fx-padding: 60 80 0 80; -fx-background-color: #f7f5f1;">
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 24 0;">
                        <VBox spacing="4">
                            <Label text="GALERIE PHOTOS"
                                   style="-fx-text-fill: #c8956c; -fx-font-size: 10px;
                                          -fx-font-weight: 700;"/>
                            <Label fx:id="lblGalerieTitre"
                                   style="-fx-text-fill: #1a1814; -fx-font-size: 32px;
                                          -fx-font-weight: 400; -fx-font-family: Georgia;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblGalerieCount"
                               style="-fx-text-fill: #a8a4a0; -fx-font-size: 13px;"/>
                    </HBox>
                    <HBox fx:id="galerieContainer" spacing="12"/>
                </VBox>

                <Region prefHeight="80" style="-fx-background-color: #f7f5f1;"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
