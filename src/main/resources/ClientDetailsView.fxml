<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.destination.controllers.ClientDetailsController"
            stylesheets="@app.css"
            styleClass="root-dark">

    <!-- HEADER -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="page">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Button fx:id="btnBackToList" text="← Back" styleClass="btn-secondary"/>
            <Label text="Destination Details" styleClass="pageTitle"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="20" styleClass="page">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Destination Info -->
                <VBox spacing="10">
                    <Label fx:id="lblName" styleClass="details-title"/>
                    <Label fx:id="lblCountry" styleClass="details-text"/>
                    <Label fx:id="lblDescription" wrapText="true" styleClass="details-text"/>
                    <HBox spacing="20">
                        <Label fx:id="lblSeason" styleClass="details-text"/>
                        <Label fx:id="lblVisits" styleClass="details-text"/>
                        <Label fx:id="lblTotal" styleClass="details-highlight"/>
                    </HBox>
                </VBox>

                <!-- Dates -->
                <HBox spacing="20">
                    <Label text="Departure:" styleClass="details-text"/>
                    <Label fx:id="lblDepart" styleClass="details-text"/>
                    <Label text="Arrival:" styleClass="details-text"/>
                    <Label fx:id="lblArrival" styleClass="details-text"/>
                </HBox>

                <!-- Main Image -->
                <VBox spacing="10" alignment="CENTER">
                    <ImageView fx:id="imageView"
                               fitWidth="600"
                               fitHeight="350"
                               preserveRatio="true"/>
                    <HBox spacing="20" alignment="CENTER">
                        <Button fx:id="btnPrev" text="◀ Précédent" styleClass="btn-secondary"/>
                        <Button fx:id="btnNext" text="Suivant ▶" styleClass="btn-primary"/>
                    </HBox>
                </VBox>

                <!-- Image Thumbnails -->
                <HBox fx:id="imagesContainer" spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                </HBox>

                <!-- Carte OpenStreetMap -->
                <BorderPane fx:id="mapPane"
                            prefHeight="400"
                            style="-fx-background-color: #ddd; -fx-border-color: #ccc; -fx-border-width: 1;"/>

                <!-- Distance / Durée / Transport -->
                <HBox spacing="20"
                      style="-fx-padding: 10; -fx-background-color: #f5f5f5; -fx-border-radius: 10; -fx-background-radius: 10;">
                    <Label fx:id="lblDistance" text="Distance: -" styleClass="details-text"/>
                    <Label fx:id="lblDuration" text="Durée: -" styleClass="details-text"/>
                    <Label fx:id="lblTransport" text="Transport: Voiture" styleClass="details-text"/>
                    <Button fx:id="btnReserve" text="Réserver" styleClass="btn-primary"/>
                </HBox>

                <!-- Transports -->
                <VBox fx:id="transportContainer" spacing="10"/>

                <!-- ============================= -->
                <!-- 🌤️ MÉTÉO                      -->
                <!-- ============================= -->
                <VBox fx:id="weatherBox"
                      spacing="12"
                      visible="false"
                      style="-fx-background-color: linear-gradient(to bottom right, #1a6fa8, #0d3b6e);
                             -fx-background-radius: 16;
                             -fx-padding: 18;">

                    <!-- Titre + Période -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🌤️ Météo à destination"
                               style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblWeatherPeriod"
                               style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
                    </HBox>

                    <!-- Température + Détails -->
                    <HBox spacing="20" alignment="CENTER_LEFT">
                        <VBox spacing="4" alignment="CENTER_LEFT">
                            <Label fx:id="lblWeatherTemp"
                                   style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                            <Label fx:id="lblWeatherDesc"
                                   style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;"/>
                            <Label fx:id="lblWeatherCity"
                                   style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12px;"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox spacing="8" alignment="CENTER_RIGHT">
                            <Label fx:id="lblWeatherFeels"
                                   style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
                            <Label fx:id="lblWeatherHumidity"
                                   style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
                            <Label fx:id="lblWeatherWind"
                                   style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
                        </VBox>
                    </HBox>

                    <!-- Indice voyage -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Indice voyage :"
                               style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 13px;"/>
                        <Label fx:id="lblWeatherIndex"
                               style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </HBox>

                    <Separator style="-fx-background-color: rgba(255,255,255,0.25);"/>

                    <!-- Prévisions 5 jours -->
                    <Label text="Prévisions 5 jours"
                           style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 12px; -fx-font-weight: bold;"/>

                    <HBox fx:id="forecastContainer" spacing="8" alignment="CENTER"/>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
