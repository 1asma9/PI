<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.destination.controllers.ClientDetailsController"
            stylesheets="@/app/app.css"
            style="-fx-background-color: #f5f0e8;">

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  HEADER                                                 -->
    <!-- ══════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #faf7f2;
                     -fx-padding: 16 44 16 44;
                     -fx-border-color: #e8e0d0;
                     -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian, rgba(100,80,40,0.07), 10, 0, 0, 3);">

            <Button fx:id="btnBackToList" text="← Retour"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #8a7560;
                           -fx-font-size: 12px; -fx-font-weight: 600;
                           -fx-border-color: #d8cfc0;
                           -fx-border-radius: 6; -fx-background-radius: 6;
                           -fx-border-width: 1; -fx-padding: 8 18 8 18;
                           -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="✦  VOYAGE &amp; DÉCOUVERTE  ✦"
                   style="-fx-text-fill: #c8b898; -fx-font-size: 11px; -fx-font-weight: 700;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: #f0f7f0;
                         -fx-border-color: #a8d4a8; -fx-border-radius: 6;
                         -fx-background-radius: 6; -fx-border-width: 1;
                         -fx-padding: 7 18 7 18;">
                <Label text="●" style="-fx-text-fill: #4a9e4a; -fx-font-size: 8px;"/>
                <Label text="Disponible"
                       style="-fx-text-fill: #4a9e4a; -fx-font-size: 11px; -fx-font-weight: 700;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: #f5f0e8; -fx-background-color: #f5f0e8;
                           -fx-border-color: transparent;">
            <VBox spacing="0" style="-fx-background-color: #f5f0e8;">

                <!-- HERO -->
                <StackPane minHeight="580" prefHeight="620">
                    <ImageView fx:id="imageView" fitWidth="1280" fitHeight="620"
                               preserveRatio="false" style="-fx-smooth: true;"/>
                    <VBox style="-fx-background-color: linear-gradient(to right,
                                     rgba(30,20,10,0.85) 0%, rgba(30,20,10,0.55) 45%,
                                     transparent 80%);" prefHeight="620"/>
                    <VBox style="-fx-background-color: linear-gradient(to top,
                                     rgba(245,240,232,1.0) 0%, rgba(245,240,232,0.6) 18%,
                                     transparent 45%);" prefHeight="620"/>
                    <VBox alignment="BOTTOM_LEFT" prefHeight="620"
                          style="-fx-padding: 0 80 60 80;">
                        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 12 0;">
                            <Label text="—" style="-fx-text-fill: #d4a855; -fx-font-size: 14px;"/>
                            <Label fx:id="lblCountry"
                                   style="-fx-text-fill: #d4a855; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                        </HBox>
                        <Label fx:id="lblName"
                               style="-fx-text-fill: white; -fx-font-size: 76px; -fx-font-weight: 900;
                                      -fx-font-family: 'Georgia';
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 24, 0, 0, 4);"/>
                        <Region prefHeight="22"/>
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <VBox spacing="3"
                                  style="-fx-background-color: rgba(255,255,255,0.92);
                                         -fx-background-radius: 10; -fx-padding: 12 26 12 26;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 14, 0, 0, 5);">
                                <Label text="À PARTIR DE"
                                       style="-fx-text-fill: #a89070; -fx-font-size: 9px; -fx-font-weight: 800;"/>
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label fx:id="lblTotal"
                                           style="-fx-text-fill: #2c1f0e; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                                    <Label text="TND"
                                           style="-fx-text-fill: #a89070; -fx-font-size: 13px; -fx-font-weight: 700;"/>
                                </HBox>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox spacing="0" alignment="CENTER"
                                  style="-fx-background-color: rgba(255,255,255,0.18);
                                         -fx-border-color: rgba(255,255,255,0.35);
                                         -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;">
                                <Button fx:id="btnPrev" text="←"
                                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.65);
                                               -fx-font-size: 15px; -fx-font-weight: 700;
                                               -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
                                <Separator orientation="VERTICAL"
                                           style="-fx-background-color: rgba(255,255,255,0.25);" prefHeight="16"/>
                                <Button fx:id="btnNext" text="→"
                                        style="-fx-background-color: transparent; -fx-text-fill: white;
                                               -fx-font-size: 15px; -fx-font-weight: 700;
                                               -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
                            </HBox>
                        </HBox>
                    </VBox>
                </StackPane>

                <!-- STATS -->
                <HBox spacing="0"
                      style="-fx-background-color: #faf7f2;
                             -fx-border-color: #e8e0d0; -fx-border-width: 0 0 1 0;
                             -fx-effect: dropshadow(gaussian, rgba(100,80,40,0.08), 8, 0, 0, 3);">
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-padding: 26 20 26 20;
                                 -fx-border-color: transparent #e8e0d0 transparent transparent;
                                 -fx-border-width: 0 1 0 0;">
                        <Label text="DÉPART" style="-fx-text-fill: #c8b898; -fx-font-size: 9px; -fx-font-weight: 800;"/>
                        <Region prefHeight="6"/>
                        <Label fx:id="lblDepart"
                               style="-fx-text-fill: #2c1f0e; -fx-font-size: 16px;
                                      -fx-font-weight: 800; -fx-font-family: 'Georgia';"/>
                        <Region prefHeight="6"/>
                        <Label text="✈" style="-fx-text-fill: #d4a855; -fx-font-size: 14px;"/>
                    </VBox>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-padding: 26 20 26 20;
                                 -fx-border-color: transparent #e8e0d0 transparent transparent;
                                 -fx-border-width: 0 1 0 0;">
                        <Label text="ARRIVÉE" style="-fx-text-fill: #c8b898; -fx-font-size: 9px; -fx-font-weight: 800;"/>
                        <Region prefHeight="6"/>
                        <Label fx:id="lblArrival"
                               style="-fx-text-fill: #2c1f0e; -fx-font-size: 16px;
                                      -fx-font-weight: 800; -fx-font-family: 'Georgia';"/>
                        <Region prefHeight="6"/>
                        <Label text="🏁" style="-fx-font-size: 14px;"/>
                    </VBox>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-padding: 26 20 26 20;
                                 -fx-border-color: transparent #e8e0d0 transparent transparent;
                                 -fx-border-width: 0 1 0 0;">
                        <Label text="MEILLEURE SAISON" style="-fx-text-fill: #c8b898; -fx-font-size: 9px; -fx-font-weight: 800;"/>
                        <Region prefHeight="6"/>
                        <Label fx:id="lblSeason"
                               style="-fx-text-fill: #2c1f0e; -fx-font-size: 16px;
                                      -fx-font-weight: 800; -fx-font-family: 'Georgia';"/>
                        <Region prefHeight="6"/>
                        <Label text="🌿" style="-fx-font-size: 14px;"/>
                    </VBox>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-padding: 26 20 26 20;">
                        <Label text="VISITES TOTALES" style="-fx-text-fill: #c8b898; -fx-font-size: 9px; -fx-font-weight: 800;"/>
                        <Region prefHeight="6"/>
                        <Label fx:id="lblVisits"
                               style="-fx-text-fill: #2c1f0e; -fx-font-size: 16px;
                                      -fx-font-weight: 800; -fx-font-family: 'Georgia';"/>
                        <Region prefHeight="6"/>
                        <Label text="👁" style="-fx-font-size: 14px;"/>
                    </VBox>
                </HBox>

                <!-- GALERIE -->
                <HBox fx:id="imagesContainer" spacing="8"
                      style="-fx-padding: 24 44 0 44; -fx-background-color: #f5f0e8;"/>

                <!-- 2 COLONNES -->
                <HBox spacing="22" style="-fx-padding: 28 44 0 44; -fx-background-color: #f5f0e8;">
                    <VBox spacing="22" HBox.hgrow="ALWAYS">
                        <!-- À propos -->
                        <VBox spacing="0"
                              style="-fx-background-color: #faf7f2; -fx-background-radius: 14;
                                     -fx-border-color: #e8e0d0; -fx-border-radius: 14; -fx-border-width: 1;
                                     -fx-effect: dropshadow(gaussian, rgba(100,80,40,0.07), 12, 0, 0, 4);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding: 18 24 18 24; -fx-border-color: #ede5d8; -fx-border-width: 0 0 1 0;">
                                <Label text="À PROPOS"
                                       style="-fx-text-fill: #c8b898; -fx-font-size: 10px; -fx-font-weight: 800;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="✦" style="-fx-text-fill: #d4a855; -fx-font-size: 11px;"/>
                            </HBox>
                            <VBox spacing="14" style="-fx-padding: 26 28 26 28;">
                                <Label text="Description de la destination"
                                       style="-fx-text-fill: #2c1f0e; -fx-font-size: 20px;
                                              -fx-font-weight: 800; -fx-font-family: 'Georgia';"/>
                                <Label fx:id="lblDescription" wrapText="true"
                                       style="-fx-text-fill: #8a7560; -fx-font-size: 13px; -fx-line-spacing: 6;"/>
                            </VBox>
                        </VBox>
                        <!-- Transports -->
                        <VBox spacing="0"
                              style="-fx-background-color: #faf7f2; -fx-background-radius: 14;
                                     -fx-border-color: #e8e0d0; -fx-border-radius: 14; -fx-border-width: 1;
                                     -fx-effect: dropshadow(gaussian, rgba(100,80,40,0.07), 12, 0, 0, 4);">
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-padding: 18 24 18 24; -fx-border-color: #ede5d8; -fx-border-width: 0 0 1 0;">
                                <Label text="TRANSPORTS DISPONIBLES"
                                       style="-fx-text-fill: #c8b898; -fx-font-size: 10px; -fx-font-weight: 800;"/>
                            </HBox>
                            <VBox fx:id="transportContainer" spacing="8"
                                  style="-fx-padding: 18 24 18 24;"/>
                        </VBox>
                    </VBox>

                    <!-- Carte -->
                    <VBox spacing="0" minWidth="480" maxWidth="520"
                          style="-fx-background-color: #faf7f2; -fx-background-radius: 14;
                                 -fx-border-color: #e8e0d0; -fx-border-radius: 14; -fx-border-width: 1;
                                 -fx-effect: dropshadow(gaussian, rgba(100,80,40,0.08), 14, 0, 0, 5);">
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-padding: 18 24 18 24; -fx-border-color: #ede5d8; -fx-border-width: 0 0 1 0;">
                            <Label text="CARTE &amp; ITINÉRAIRE"
                                   style="-fx-text-fill: #c8b898; -fx-font-size: 10px; -fx-font-weight: 800;"/>
                        </HBox>
                        <BorderPane fx:id="mapPane" prefHeight="330"
                                    style="-fx-background-color: #e8e0d0;"/>
                        <HBox spacing="0"
                              style="-fx-background-color: #f5f0e8; -fx-border-color: #e8e0d0;
                                     -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 14 14;">
                            <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                                  style="-fx-padding: 16 10 16 10;">
                                <Label text="DISTANCE" style="-fx-text-fill: #c8b898; -fx-font-size: 9px; -fx-font-weight: 800;"/>
                                <Label fx:id="lblDistance" text="—"
                                       style="-fx-text-fill: #2c1f0e; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                            </VBox>
                            <Separator orientation="VERTICAL"
                                       style="-fx-background-color: #e8e0d0;" prefHeight="36"/>
                            <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                                  style="-fx-padding: 16 10 16 10;">
                                <Label text="DURÉE" style="-fx-text-fill: #c8b898; -fx-font-size: 9px; -fx-font-weight: 800;"/>
                                <Label fx:id="lblDuration" text="—"
                                       style="-fx-text-fill: #2c1f0e; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                            </VBox>
                            <Separator orientation="VERTICAL"
                                       style="-fx-background-color: #e8e0d0;" prefHeight="36"/>
                            <VBox spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS"
                                  style="-fx-padding: 16 10 16 10;">
                                <Label text="TRANSPORT" style="-fx-text-fill: #c8b898; -fx-font-size: 9px; -fx-font-weight: 800;"/>
                                <Label fx:id="lblTransport" text="—"
                                       style="-fx-text-fill: #2c1f0e; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ════════════════════════════════════════════ -->
                <!--  MÉTÉO — Moderne, cards colorées, temp badge  -->
                <!-- ════════════════════════════════════════════ -->
                <VBox fx:id="weatherBox"
                      spacing="0"
                      visible="false"
                      style="-fx-background-color: #faf7f2;
                             -fx-background-radius: 16;
                             -fx-border-color: #e8e0d0;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian, rgba(100,80,40,0.1), 16, 0, 0, 6);">
                    <VBox.margin>
                        <Insets top="28" right="44" bottom="0" left="44"/>
                    </VBox.margin>

                    <!-- Header -->
                    <HBox alignment="CENTER_LEFT"
                          style="-fx-padding: 22 28 22 28;
                                 -fx-border-color: #ede5d8;
                                 -fx-border-width: 0 0 1 0;">
                        <VBox spacing="4">
                            <Label text="MÉTÉO À DESTINATION"
                                   style="-fx-text-fill: #c8b898;
                                          -fx-font-size: 10px; -fx-font-weight: 800;"/>
                            <Label fx:id="lblWeatherCity"
                                   style="-fx-text-fill: #2c1f0e;
                                          -fx-font-size: 20px; -fx-font-weight: 800;
                                          -fx-font-family: 'Georgia';"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox alignment="CENTER" spacing="8"
                              style="-fx-background-color: #f5f0e8;
                                     -fx-border-color: #e8e0d0;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-border-width: 1; -fx-padding: 10 20 10 20;">
                            <Label text="📅" style="-fx-font-size: 12px;"/>
                            <Label fx:id="lblWeatherPeriod"
                                   style="-fx-text-fill: #8a7560;
                                          -fx-font-size: 12px; -fx-font-weight: 600;"/>
                        </HBox>
                    </HBox>

                    <!-- Corps principal : Card temp + barres métriques -->
                    <HBox spacing="16" style="-fx-padding: 24 28 24 28;">

                        <!-- Card température avec icône -->
                        <VBox spacing="0" alignment="CENTER"
                              style="-fx-background-color: linear-gradient(to bottom, #2c4a6e, #1a2e45);
                                     -fx-background-radius: 14;
                                     -fx-min-width: 200; -fx-max-width: 200;
                                     -fx-padding: 28 20 24 20;
                                     -fx-effect: dropshadow(gaussian, rgba(30,50,80,0.3), 14, 0, 0, 6);">
                            <Label fx:id="lblWeatherTemp"
                                   style="-fx-text-fill: white;
                                          -fx-font-size: 58px;
                                          -fx-font-weight: 900;
                                          -fx-font-family: 'Georgia';"/>
                            <Label fx:id="lblWeatherDesc"
                                   style="-fx-text-fill: rgba(255,255,255,0.65);
                                          -fx-font-size: 12px;
                                          -fx-font-weight: 600;
                                          -fx-padding: 4 0 0 0;"/>
                        </VBox>

                        <!-- Métriques avec barres de progression -->
                        <VBox spacing="14" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT"
                              style="-fx-padding: 4 0 4 8;">

                            <!-- Ressenti -->
                            <VBox spacing="6">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="🌡"  style="-fx-font-size: 12px;"/>
                                    <Label text="RESSENTI"
                                           style="-fx-text-fill: #c8b898;
                                                  -fx-font-size: 9px; -fx-font-weight: 800;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblWeatherFeels"
                                           style="-fx-text-fill: #2c1f0e;
                                                  -fx-font-size: 13px; -fx-font-weight: 700;"/>
                                </HBox>
                                <ProgressBar progress="0.45" prefWidth="9999" prefHeight="5"
                                             style="-fx-accent: #4a7fa8;
                                                    -fx-background-color: #ede5d8;
                                                    -fx-background-radius: 4;
                                                    -fx-border-radius: 4;"/>
                            </VBox>

                            <Separator style="-fx-background-color: #ede5d8;"/>

                            <!-- Humidité -->
                            <VBox spacing="6">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="💧" style="-fx-font-size: 12px;"/>
                                    <Label text="HUMIDITÉ"
                                           style="-fx-text-fill: #c8b898;
                                                  -fx-font-size: 9px; -fx-font-weight: 800;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblWeatherHumidity"
                                           style="-fx-text-fill: #2c1f0e;
                                                  -fx-font-size: 13px; -fx-font-weight: 700;"/>
                                </HBox>
                                <ProgressBar progress="0.80" prefWidth="9999" prefHeight="5"
                                             style="-fx-accent: #5b9bd5;
                                                    -fx-background-color: #ede5d8;
                                                    -fx-background-radius: 4;
                                                    -fx-border-radius: 4;"/>
                            </VBox>

                            <Separator style="-fx-background-color: #ede5d8;"/>

                            <!-- Vent -->
                            <VBox spacing="6">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="💨" style="-fx-font-size: 12px;"/>
                                    <Label text="VENT"
                                           style="-fx-text-fill: #c8b898;
                                                  -fx-font-size: 9px; -fx-font-weight: 800;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblWeatherWind"
                                           style="-fx-text-fill: #2c1f0e;
                                                  -fx-font-size: 13px; -fx-font-weight: 700;"/>
                                </HBox>
                                <ProgressBar progress="0.25" prefWidth="9999" prefHeight="5"
                                             style="-fx-accent: #7ec8c8;
                                                    -fx-background-color: #ede5d8;
                                                    -fx-background-radius: 4;
                                                    -fx-border-radius: 4;"/>
                            </VBox>

                            <Separator style="-fx-background-color: #ede5d8;"/>

                            <!-- Indice voyage -->
                            <HBox alignment="CENTER_LEFT" spacing="10"
                                  style="-fx-background-color: #f5f0e8;
                                         -fx-background-radius: 8;
                                         -fx-border-color: #e8e0d0;
                                         -fx-border-radius: 8; -fx-border-width: 1;
                                         -fx-padding: 12 18 12 18;">
                                <Label text="INDICE VOYAGE"
                                       style="-fx-text-fill: #c8b898;
                                              -fx-font-size: 9px; -fx-font-weight: 800;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblWeatherIndex"
                                       style="-fx-font-size: 13px; -fx-font-weight: 800;"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Prévisions 5 jours — Cards colorées -->
                    <VBox spacing="14"
                          style="-fx-padding: 0 28 28 28;
                                 -fx-border-color: #ede5d8;
                                 -fx-border-width: 1 0 0 0;">
                        <Label text="PRÉVISIONS 5 JOURS"
                               style="-fx-text-fill: #c8b898;
                                      -fx-font-size: 10px; -fx-font-weight: 800;
                                      -fx-padding: 20 0 4 0;"/>
                        <HBox fx:id="forecastContainer" spacing="12" alignment="CENTER_LEFT"/>
                    </VBox>
                </VBox>

                <!-- BOUTON VIDÉO -->
                <HBox alignment="CENTER"
                      style="-fx-padding: 40 0 0 0; -fx-background-color: #f5f0e8;">
                    <Button fx:id="btnWatchVideo"
                            text="▶  Regarder la vidéo promotionnelle"
                            onAction="#handleWatchVideo"
                            visible="false" managed="false"
                            style="-fx-background-color: #2c1f0e;
                                   -fx-text-fill: #f5f0e8;
                                   -fx-font-size: 13px; -fx-font-weight: 700;
                                   -fx-background-radius: 8; -fx-padding: 16 48 16 48;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(44,31,14,0.35), 16, 0, 0, 6);"/>
                </HBox>

                <!-- SECTION VIDÉO -->
                <VBox fx:id="videoSection" visible="false" managed="false" spacing="0"
                      style="-fx-background-color: #0f0d0a;">
                    <VBox.margin><Insets top="0" right="0" bottom="48" left="0"/></VBox.margin>

                    <HBox alignment="CENTER_LEFT" spacing="14"
                          style="-fx-background-color: #1a150f; -fx-padding: 16 28 16 28;
                                 -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                        <Label text="▶" style="-fx-text-fill: #d4a855; -fx-font-size: 11px;"/>
                        <Label fx:id="lblVideoTitle" text="Vidéo promotionnelle"
                               style="-fx-text-fill: rgba(255,255,255,0.6);
                                      -fx-font-size: 13px; -fx-font-weight: 600;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnCloseVideo" text="✕  Fermer" onAction="#handleCloseVideo"
                                style="-fx-background-color: rgba(255,255,255,0.06);
                                       -fx-text-fill: rgba(255,255,255,0.4);
                                       -fx-font-weight: 600; -fx-font-size: 11px;
                                       -fx-border-color: rgba(255,255,255,0.1);
                                       -fx-border-radius: 6; -fx-background-radius: 6;
                                       -fx-border-width: 1; -fx-padding: 7 16 7 16; -fx-cursor: hand;"/>
                    </HBox>

                    <StackPane fx:id="videoContainer" minHeight="400" prefHeight="430"
                               prefWidth="1200" alignment="CENTER"
                               style="-fx-background-color: #050402;">
                        <VBox fx:id="videoLoadingPane" alignment="CENTER" spacing="18">
                            <ProgressIndicator prefWidth="44" prefHeight="44"
                                               style="-fx-accent: #d4a855;"/>
                            <Label fx:id="lblVideoLoading" text="Chargement..."
                                   style="-fx-text-fill: rgba(255,255,255,0.2);
                                          -fx-font-size: 11px; -fx-font-weight: 600;"/>
                        </VBox>
                        <VBox fx:id="videoErrorPane" alignment="CENTER" spacing="14"
                              visible="false" managed="false">
                            <Label text="⚠" style="-fx-text-fill: #d4a855; -fx-font-size: 36px;"/>
                            <Label fx:id="lblVideoError" text="Vidéo introuvable" wrapText="true"
                                   style="-fx-text-fill: rgba(255,255,255,0.3);
                                          -fx-font-size: 13px; -fx-alignment: center;"/>
                        </VBox>
                    </StackPane>

                    <HBox fx:id="videoControls" alignment="CENTER_LEFT" spacing="12"
                          visible="false" managed="false"
                          style="-fx-background-color: #1a150f; -fx-padding: 14 24 14 24;
                                 -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 1 0 0 0;">
                        <Button fx:id="btnPlayPause" text="⏸  Pause" onAction="#handlePlayPause"
                                style="-fx-background-color: #d4a855; -fx-text-fill: #1a150f;
                                       -fx-font-size: 12px; -fx-font-weight: 800;
                                       -fx-background-radius: 6; -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>
                        <Button fx:id="btnStop" text="⏹  Stop" onAction="#handleStop"
                                style="-fx-background-color: rgba(255,255,255,0.06);
                                       -fx-text-fill: rgba(255,255,255,0.45);
                                       -fx-font-size: 12px; -fx-font-weight: 600;
                                       -fx-background-radius: 6; -fx-border-color: rgba(255,255,255,0.1);
                                       -fx-border-radius: 6; -fx-border-width: 1;
                                       -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>
                        <Slider fx:id="timeSlider" min="0" max="100" value="0"
                                HBox.hgrow="ALWAYS" style="-fx-accent: #d4a855;"/>
                        <Label fx:id="lblVideoTime" text="0:00 / 0:00"
                               style="-fx-text-fill: rgba(255,255,255,0.22); -fx-font-size: 11px;"/>
                        <Label text="🔊" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.3);"/>
                        <Slider fx:id="volumeSlider" min="0" max="1" value="1.0"
                                prefWidth="80" style="-fx-accent: #d4a855;"/>
                    </HBox>
                </VBox>

                <Region prefHeight="60" style="-fx-background-color: #f5f0e8;"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
