<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.web.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.destination.controllers.AdminDestinationFormController"
           stylesheets="@/app/destination.css"
           styleClass="root-dark">

    <ScrollPane fitToWidth="true" styleClass="root-dark">
        <VBox spacing="12" alignment="CENTER" maxWidth="620"
              style="-fx-padding: 20;" styleClass="glass-card-large">

            <Label text="Nouvelle Destination" styleClass="title-white"/>

            <TextField fx:id="txtNom" promptText="Nom" styleClass="form-field"
                       maxWidth="Infinity"/>
            <Label fx:id="errNom" styleClass="error-label"/>

            <TextField fx:id="txtPays" promptText="Pays" styleClass="form-field"
                       maxWidth="Infinity"/>
            <Label fx:id="errPays" styleClass="error-label"/>

            <TextField fx:id="txtDescription" promptText="Description"
                       styleClass="form-field" maxWidth="Infinity"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="btnGenererDescription"
                        text="Generer avec IA"
                        styleClass="btn-primary"/>
                <Label fx:id="lblIaStatus" style="-fx-font-size: 12px;"/>
            </HBox>
            <Label fx:id="errDescription" styleClass="error-label"/>

            <!-- ✅ Dropdown Meilleure Saison -->
            <Label text="Meilleure Saison"
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
            <ComboBox fx:id="comboSaison"
                      promptText="Choisir une saison..."
                      maxWidth="Infinity"
                      styleClass="form-field"/>
            <Label fx:id="errSaison" styleClass="error-label"/>

            <!-- ✅ Dropdown Statut -->
            <Label text="Statut"
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
            <ComboBox fx:id="comboStatut"
                      promptText="Choisir un statut..."
                      maxWidth="Infinity"
                      styleClass="form-field"/>

            <!-- Carte interactive -->
            <Label text="Cliquez sur la carte pour definir la position"
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
            <WebView fx:id="mapView" prefHeight="300" maxWidth="Infinity"
                     VBox.vgrow="NEVER"/>

            <HBox spacing="10">
                <TextField fx:id="txtLatitude" promptText="Latitude"
                           styleClass="form-field" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtLongitude" promptText="Longitude"
                           styleClass="form-field" HBox.hgrow="ALWAYS"/>
            </HBox>
            <HBox spacing="10">
                <Label fx:id="errLatitude" styleClass="error-label"/>
                <Label fx:id="errLongitude" styleClass="error-label"/>
            </HBox>

            <TextField fx:id="txtNbVisites" promptText="Nombre de visites"
                       styleClass="form-field" maxWidth="Infinity"/>
            <Label fx:id="errNbVisites" styleClass="error-label"/>

            <TextField fx:id="txtVideoPath"
                       promptText="URL video promotionnelle (https://...)"
                       styleClass="form-field" maxWidth="Infinity"/>
            <Label fx:id="errVideoPath" styleClass="error-label"/>

            <HBox spacing="14" alignment="CENTER">
                <Button fx:id="btnSave" text="Enregistrer" styleClass="btn-primary"/>
                <Button fx:id="btnCancel" text="Annuler" styleClass="btn-danger"/>
            </HBox>

        </VBox>
    </ScrollPane>
</StackPane>
