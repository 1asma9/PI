<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.destination.controllers.AdminVoyageDetailController"
           style="-fx-background-color:#f3f4f6;">

    <ScrollPane fitToWidth="true"
                style="-fx-background-color:transparent;-fx-border-color:transparent;">

        <VBox spacing="24" style="-fx-padding:36 48;-fx-max-width:800;">

            <!-- HEADER MODERNE -->
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color:white;
                         -fx-padding:20 24;
                         -fx-background-radius:16;
                         -fx-border-color:#e5e7eb;
                         -fx-border-radius:16;
                         -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">

                <Button fx:id="btnRetour" text="← Retour"
                        style="-fx-background-color:#f3f4f6;
                               -fx-border-color:#d1d5db;
                               -fx-background-radius:8;
                               -fx-text-fill:#374151;
                               -fx-padding:7 16;"/>

                <Label text="Détail Voyage"
                       style="-fx-text-fill:#111827;
                              -fx-font-size:22px;
                              -fx-font-weight:900;"/>

                <Label fx:id="lblVoyageId"
                       style="-fx-background-color:#ea580c;
                              -fx-text-fill:white;
                              -fx-background-radius:20;
                              -fx-padding:4 12;
                              -fx-font-weight:800;"/>
            </HBox>

            <!-- CARD VOYAGE -->
            <VBox spacing="0"
                  style="-fx-background-color:white;
                         -fx-background-radius:16;
                         -fx-border-color:#e5e7eb;
                         -fx-border-radius:16;
                         -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">

                <!-- HEADER CARD -->
                <HBox style="-fx-background-color:#f8fafc;
                             -fx-padding:14 20;
                             -fx-background-radius:16 16 0 0;">
                    <Label text="📋 Informations du voyage"
                           style="-fx-text-fill:#111827;
                                  -fx-font-weight:700;
                                  -fx-font-size:14px;"/>
                </HBox>

                <VBox spacing="16" style="-fx-padding:20;">

                    <!-- ID + PRIX -->
                    <HBox spacing="16">
                        <VBox HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#f8fafc;
                                     -fx-border-color:#e5e7eb;
                                     -fx-background-radius:12;
                                     -fx-padding:14;">
                            <Label text="ID" style="-fx-text-fill:#6b7280;"/>
                            <Label fx:id="lblId"
                                   style="-fx-text-fill:#111827;
                                          -fx-font-size:18px;
                                          -fx-font-weight:900;"/>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#f8fafc;
                                     -fx-border-color:#e5e7eb;
                                     -fx-background-radius:12;
                                     -fx-padding:14;">
                            <Label text="PRIX" style="-fx-text-fill:#6b7280;"/>
                            <Label fx:id="lblPrix"
                                   style="-fx-text-fill:#16a34a;
                                          -fx-font-size:18px;
                                          -fx-font-weight:900;"/>
                        </VBox>
                    </HBox>

                    <!-- DEPART / ARRIVEE -->
                    <HBox spacing="16">

                        <VBox HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#f8fafc;
                                     -fx-border-color:#e5e7eb;
                                     -fx-background-radius:12;
                                     -fx-padding:14;">
                            <Label text="✈ DÉPART" style="-fx-text-fill:#6b7280;"/>
                            <Label fx:id="lblPointDepart"
                                   style="-fx-text-fill:#ea580c;
                                          -fx-font-size:16px;
                                          -fx-font-weight:800;"/>
                        </VBox>

                        <Label text="→"
                               style="-fx-text-fill:#9ca3af;
                                      -fx-font-size:18px;"/>

                        <VBox HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#f8fafc;
                                     -fx-border-color:#e5e7eb;
                                     -fx-background-radius:12;
                                     -fx-padding:14;">
                            <Label text="🏁 ARRIVÉE" style="-fx-text-fill:#6b7280;"/>
                            <Label fx:id="lblPointArrivee"
                                   style="-fx-text-fill:#111827;
                                          -fx-font-size:16px;
                                          -fx-font-weight:800;"/>
                        </VBox>

                    </HBox>

                    <!-- DATES -->
                    <HBox spacing="16">

                        <VBox HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#f8fafc;
                                     -fx-border-color:#e5e7eb;
                                     -fx-background-radius:12;
                                     -fx-padding:14;">
                            <Label text="📅 DATE DE DÉPART" style="-fx-text-fill:#6b7280;"/>
                            <Label fx:id="lblDateDepart"
                                   style="-fx-text-fill:#ea580c;
                                          -fx-font-weight:700;"/>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#f8fafc;
                                     -fx-border-color:#e5e7eb;
                                     -fx-background-radius:12;
                                     -fx-padding:14;">
                            <Label text="📅 DATE D'ARRIVÉE" style="-fx-text-fill:#6b7280;"/>
                            <Label fx:id="lblDateArrivee"
                                   style="-fx-text-fill:#111827;
                                          -fx-font-weight:700;"/>
                        </VBox>

                    </HBox>

                </VBox>
            </VBox>

            <!-- CARD USERS -->
            <VBox spacing="0"
                  style="-fx-background-color:white;
                         -fx-background-radius:16;
                         -fx-border-color:#e5e7eb;
                         -fx-border-radius:16;">

                <HBox style="-fx-background-color:#f8fafc;
                             -fx-padding:14 20;
                             -fx-background-radius:16 16 0 0;">
                    <Label text="👤 Réservé par"
                           style="-fx-text-fill:#111827;
                                  -fx-font-weight:700;"/>

                    <Label fx:id="lblReservationCount"
                           style="-fx-background-color:#fff7ed;
                                  -fx-border-color:#fdba74;
                                  -fx-text-fill:#ea580c;
                                  -fx-padding:3 10;
                                  -fx-background-radius:10;"/>
                </HBox>

                <VBox fx:id="usersContainer" spacing="10"
                      style="-fx-padding:16;"/>
            </VBox>

            <!-- BUTTONS -->
            <HBox spacing="14">

                <Button fx:id="btnModifier" text="✏ Modifier"
                        style="-fx-background-color:#fff7ed;
                               -fx-border-color:#fb923c;
                               -fx-text-fill:#ea580c;
                               -fx-padding:10 24;
                               -fx-background-radius:10;
                               -fx-font-weight:700;"/>

                <Button fx:id="btnSupprimer" text="🗑 Supprimer"
                        style="-fx-background-color:#fef2f2;
                               -fx-border-color:#f87171;
                               -fx-text-fill:#dc2626;
                               -fx-padding:10 24;
                               -fx-background-radius:10;
                               -fx-font-weight:700;"/>

            </HBox>

        </VBox>
    </ScrollPane>
</StackPane>
