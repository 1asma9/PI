<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.PI_Gestion_des_utilisateurs.ui.DeleteUserController">
    
    <!-- Header -->
    <top>
        <VBox alignment="CENTER" styleClass="header">
            <Label styleClass="title" text="Supprimer un Utilisateur" />
        </VBox>
    </top>
    
    <!-- Contenu principal -->
    <center>
        <VBox alignment="CENTER" spacing="24" styleClass="main-container">
            
            <!-- Section de recherche -->
            <VBox alignment="CENTER" spacing="16">
                <Label styleClass="form-label" text="Rechercher par ID :" />
                <HBox alignment="CENTER" spacing="12">
                    <TextField fx:id="idField" prefHeight="40" prefWidth="200" promptText="Entrez l'ID" styleClass="text-field" />
                    <Button onAction="#onSearch" prefHeight="40" prefWidth="120" styleClass="button primary" text="Rechercher" />
                </HBox>
            </VBox>
            
            <!-- Tableau des utilisateurs -->
            <VBox alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS">
                <Label styleClass="subtitle" text="Liste des utilisateurs" />
                <TableView fx:id="usersTable" prefHeight="300" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="idCol" prefWidth="60" text="ID" />
                        <TableColumn fx:id="nomCol" prefWidth="120" text="Nom" />
                        <TableColumn fx:id="prenomCol" prefWidth="120" text="Prénom" />
                        <TableColumn fx:id="emailCol" prefWidth="200" text="Email" />
                    </columns>
                </TableView>
            </VBox>
            
            <!-- Boutons d'action -->
            <VBox spacing="16" styleClass="action-buttons">
                <HBox alignment="CENTER" spacing="16">
                    <Button onAction="#onDelete" prefHeight="45" prefWidth="120" styleClass="button danger" text="Supprimer" />
                    <Button onAction="#onCancel" prefHeight="45" prefWidth="120" styleClass="button cancel" text="Retour" />
                </HBox>
            </VBox>
            
        </VBox>
    </center>
    
    <!-- Marges responsives -->
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
    
</BorderPane>
