<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.AdminLayoutController"            styleClass="root">

    <left>
        <VBox fx:id="sidebar" spacing="12" styleClass="sidebar">
            <Label text="VOYAGE" styleClass="brand"/>

            <Button text="🏠 Dashboard"
                    onAction="#goDashboard"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="📅 Réservations"
                    onAction="#goReservationsAdmin"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="🏨 Hébergements"
                    onAction="#goList"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="➕ Ajouter"
                    onAction="#goAdd"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="👥 Utilisateurs"
                    onAction="#goUtilisateurs"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <!-- Dropdown Gestion Destination -->
            <VBox spacing="4">
                <Button fx:id="btnToggleDestination"
                        text="🌍 Gestion Destination ▼"
                        onAction="#toggleDestinationMenu"
                        styleClass="nav-btn"
                        maxWidth="Infinity"/>
                <VBox fx:id="destinationSubMenu" spacing="4"
                      style="-fx-padding: 0 0 0 15;"
                      visible="true" managed="true">
                    <Button text="📍 Destinations"
                            onAction="#goDestination"
                            styleClass="nav-btn"
                            maxWidth="Infinity"/>
                    <Button text="✈️ Voyages"
                            onAction="#goVoyage"
                            styleClass="nav-btn"
                            maxWidth="Infinity"/>
                    <Button text="🚌 Transports"
                            onAction="#goTransport"
                            styleClass="nav-btn"
                            maxWidth="Infinity"/>
                    <Button text="🖼️ Images"
                            onAction="#goImage"
                            styleClass="nav-btn"
                            maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <Button text="💬 Chat"
                    onAction="#goChat"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="📝 Blog"
                    onAction="#goBlogList"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="📊 Dashboard Blog"
                    onAction="#goBlogDashboard"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="🚨 Réclamations"
                    onAction="#goAdminReclamations"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="🎯 Activités"
                    onAction="#goActiviteBack"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪 Déconnexion"
                    onAction="#goLogout"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>
            <Label fx:id="connectedLabel" text="Admin" styleClass="pill"/>
            <Label text="© 2026" styleClass="muted"/>
        </VBox>
    </left>

    <top>
        <HBox styleClass="header" spacing="10">
            <Label fx:id="pageTitle" text="Dashboard" styleClass="title"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" styleClass="content"/>
    </center>

</BorderPane>