<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="hebergement.controllers.MonEspaceController"
            styleClass="content">

    <top>
        <VBox spacing="6" styleClass="content">
            <Label text="Mon Espace" styleClass="h1"/>
            <Label fx:id="lblUser" styleClass="muted"/>
            <Label fx:id="lblProfil" styleClass="muted"/>
        </VBox>
    </top>

    <center>
        <TabPane>

            <Tab text="🏠 Hébergements" closable="false">
                <VBox spacing="10" styleClass="content">
                    <TableView fx:id="tvHebergements" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colHebId" text="ID" prefWidth="70"/>
                            <TableColumn fx:id="colHebDesc" text="Description" prefWidth="240"/>
                            <TableColumn fx:id="colHebAdresse" text="Adresse" prefWidth="240"/>
                            <TableColumn fx:id="colHebPrix" text="Prix" prefWidth="100"/>
                            <TableColumn fx:id="colHebType" text="Type" prefWidth="140"/>
                        </columns>
                    </TableView>
                    <Label fx:id="lblHebMsg" styleClass="muted"/>
                </VBox>
            </Tab>

            <Tab text="📝 Mes Blogs" closable="false">
                <VBox spacing="10" styleClass="content">
                    <TableView fx:id="tvBlogs" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colBlogId" text="ID" prefWidth="70"/>
                            <TableColumn fx:id="colBlogTitre" text="Titre" prefWidth="320"/>
                            <TableColumn fx:id="colBlogDate" text="Date" prefWidth="180"/>
                        </columns>
                    </TableView>
                    <Label fx:id="lblBlogMsg" styleClass="muted"/>
                </VBox>
            </Tab>

            <Tab text="🚨 Mes Réclamations" closable="false">
                <VBox spacing="10" styleClass="content">
                    <TableView fx:id="tvReclamations" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colRecId" text="ID" prefWidth="70"/>
                            <TableColumn fx:id="colRecSujet" text="Sujet" prefWidth="320"/>
                            <TableColumn fx:id="colRecStatut" text="Statut" prefWidth="140"/>
                            <TableColumn fx:id="colRecDate" text="Date" prefWidth="180"/>
                        </columns>
                    </TableView>
                    <Label fx:id="lblRecMsg" styleClass="muted"/>
                </VBox>
            </Tab>

            <Tab text="📅 Mes Réservations" closable="false">
                <VBox spacing="10" styleClass="content">
                    <TableView fx:id="tvReservations" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colResId" text="ID" prefWidth="70"/>
                            <TableColumn fx:id="colResDebut" text="Début" prefWidth="140"/>
                            <TableColumn fx:id="colResFin" text="Fin" prefWidth="140"/>
                            <TableColumn fx:id="colResTotal" text="Total" prefWidth="120"/>
                        </columns>
                    </TableView>
                    <Label fx:id="lblResMsg" styleClass="muted"/>
                </VBox>
            </Tab>

            <Tab text="🎯 Mes Activités" closable="false">
                <VBox spacing="10" styleClass="content">
                    <TableView fx:id="tvActivites" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colActId" text="ID" prefWidth="70"/>
                            <TableColumn fx:id="colActNom" text="Nom" prefWidth="280"/>
                            <TableColumn fx:id="colActType" text="Type" prefWidth="200"/>
                            <TableColumn fx:id="colActPrix" text="Prix" prefWidth="120"/>
                        </columns>
                    </TableView>
                    <Label fx:id="lblActMsg" styleClass="muted"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>