<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.PI_Gestion_des_utilisateurs.ui.EditUserController">
    
    <!-- Header -->
    <top>
        <VBox alignment="CENTER" styleClass="header">
            <Label styleClass="title" text="Modifier un Utilisateur" />
        </VBox>
    </top>
    
    <!-- Contenu principal -->
    <center>
        <VBox alignment="CENTER" spacing="24" styleClass="main-container">
            
            <!-- Section de recherche -->
            <VBox alignment="CENTER" spacing="16">
                <Label styleClass="subtitle" text="Rechercher un utilisateur :" />
                <HBox alignment="CENTER" spacing="16">
                    <VBox alignment="CENTER" spacing="8">
                        <Label styleClass="form-label" text="ID :" />
                        <TextField fx:id="searchIdField" prefHeight="40" prefWidth="120" promptText="ID" styleClass="text-field" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="8">
                        <Label styleClass="form-label" text="Email :" />
                        <TextField fx:id="searchEmailField" prefHeight="40" prefWidth="200" promptText="Email" styleClass="text-field" />
                    </VBox>
                    <Button onAction="#onSearch" prefHeight="40" prefWidth="120" styleClass="button primary" text="Rechercher" />
                </HBox>
            </VBox>
            
            <!-- Tableau des utilisateurs -->
            <VBox alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS">
                <TableView fx:id="usersTable" prefHeight="200" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="idCol" prefWidth="60" text="ID" />
                        <TableColumn fx:id="nomCol" prefWidth="120" text="Nom" />
                        <TableColumn fx:id="prenomCol" prefWidth="120" text="Prénom" />
                        <TableColumn fx:id="emailCol" prefWidth="200" text="Email" />
                    </columns>
                </TableView>
            </VBox>
            
            <!-- Formulaire de modification -->
            <VBox alignment="CENTER" spacing="20">
                <Label styleClass="subtitle" text="Formulaire de modification :" />
                <GridPane hgap="20" styleClass="grid-pane" vgap="16">
                    
                    <!-- Nom -->
                    <Label styleClass="form-label" text="Nom :" GridPane.columnIndex="0" GridPane.halignment="LEFT" GridPane.rowIndex="0" />
                    <TextField fx:id="nomField" prefHeight="40" promptText="Entrez le nom" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    
                    <!-- Prénom -->
                    <Label styleClass="form-label" text="Prénom :" GridPane.columnIndex="0" GridPane.halignment="LEFT" GridPane.rowIndex="1" />
                    <TextField fx:id="prenomField" prefHeight="40" promptText="Entrez le prénom" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    
                    <!-- Email -->
                    <Label styleClass="form-label" text="Email :" GridPane.columnIndex="0" GridPane.halignment="LEFT" GridPane.rowIndex="2" />
                    <TextField fx:id="emailField" prefHeight="40" promptText="exemple@email.com" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    
                    <!-- Mot de passe -->
                    <Label styleClass="form-label" text="Mot de passe :" GridPane.columnIndex="0" GridPane.halignment="LEFT" GridPane.rowIndex="3" />
                    <PasswordField fx:id="passwordField" prefHeight="40" promptText="Entrez le mot de passe" styleClass="password-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    
                    <!-- Téléphone -->
                    <Label styleClass="form-label" text="Téléphone :" GridPane.columnIndex="0" GridPane.halignment="LEFT" GridPane.rowIndex="4" />
                    <TextField fx:id="telephoneField" prefHeight="40" promptText="Numéro de téléphone" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="4" />
               <columnConstraints>
                  <ColumnConstraints />
                  <ColumnConstraints />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                    
                </GridPane>
            </VBox>
            
            <!-- Boutons d'action -->
            <VBox spacing="16" styleClass="action-buttons">
                <HBox alignment="CENTER" spacing="16">
                    <Button onAction="#onUpdate" prefHeight="45" prefWidth="120" styleClass="button primary" text="Sauvegarder" />
                    <Button onAction="#onCancel" prefHeight="45" prefWidth="120" styleClass="button cancel" text="Retour" />
                </HBox>
            </VBox>
            
        </VBox>
    </center>
    
    <!-- Marges responsives -->
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
    
</BorderPane>
