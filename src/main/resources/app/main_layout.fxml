<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="hebergement.controllers.MainLayoutController"
            styleClass="root">

    <!-- Sidebar -->
    <left>
        <VBox spacing="12" styleClass="sidebar">
            <Label text="VOYAGE" styleClass="brand"/>

            <!-- TOUS LES UTILISATEURS -->
            <Button text="🏠 Dashboard"
                    onAction="#goDashboard"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="📅 Réserver"
                    onAction="#goReservation"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button text="💬 Chat"
                    onAction="#goChat"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <!-- ADMIN SEULEMENT -->
            <Label text="─── Admin ───"
                   styleClass="muted"/>

            <Button fx:id="btnAdd"
                    text="➕ Ajouter"
                    onAction="#goAdd"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button fx:id="btnList"
                    text="📋 Gérer Hébergements"
                    onAction="#goList"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button fx:id="btnReservationsAdmin"
                    text="🛠 Réservations Admin"
                    onAction="#goReservationsAdmin"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Button fx:id="btnUtilisateurs"
                    text="👥 Utilisateurs"
                    onAction="#goUtilisateurs"
                    styleClass="nav-btn"
                    maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Label fx:id="connectedLabel"
                   text="Connecté"
                   styleClass="pill"/>
            <Label text="© 2026" styleClass="muted"/>
        </VBox>
    </left>

    <!-- Header -->
    <top>
        <HBox styleClass="header" spacing="10">
            <Label fx:id="pageTitle"
                   text="Dashboard"
                   styleClass="title"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <StackPane fx:id="contentPane"
                   styleClass="content"/>
    </center>

</BorderPane>