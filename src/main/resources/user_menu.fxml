<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="800.0" 
            styleClass="page"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controllers.UserMenuController">
   
   <!-- Top Bar -->
   <top>
      <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="15">
         <Button text="← Retour" styleClass="btnOutline" onAction="#retourMenu" />
         <Label text="ESPACE USER" styleClass="pageTitle" />
      </HBox>
   </top>
   
   <!-- Center Content -->
   <center>
      <HBox alignment="CENTER" spacing="30" styleClass="pageContent">
         
         <!-- Card Réclamations -->
         <VBox styleClass="card" alignment="CENTER" spacing="15" 
               prefWidth="300" prefHeight="250" onMouseClicked="#goToReclamationsClick">
            <Label text="📋" style="-fx-font-size: 48px;" />
            <Label text="MES RÉCLAMATIONS" styleClass="cardTitle" />
            <Label text="Gérer vos réclamations" styleClass="metaText" />
            <Button text="Accéder" styleClass="btnGold" onAction="#goToReclamations" />
         </VBox>
         
         <!-- Card Avis -->
         <VBox styleClass="card" alignment="CENTER" spacing="15" 
               prefWidth="300" prefHeight="250" onMouseClicked="#goToAvisClick">
            <Label text="⭐" style="-fx-font-size: 48px;" />
            <Label text="MES AVIS" styleClass="cardTitle" />
            <Label text="Gérer vos avis" styleClass="metaText" />
            <Button text="Accéder" styleClass="btnGold" onAction="#goToAvis" />
         </VBox>
         
      </HBox>
   </center>
   
</BorderPane>
