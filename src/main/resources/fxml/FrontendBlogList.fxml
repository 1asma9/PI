<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import javafx.scene.shape.Rectangle?>
<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="750.0" prefWidth="1366.0" style="-fx-background-color: #ffffff;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a8.controllers.FrontendBlogController">

    <!-- Header/Navbar -->
    <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="1366.0"
          style="-fx-background-color: #1a1a1a;">
        <padding>
            <Insets left="60.0" right="60.0"/>
        </padding>
        <children>
            <!-- Logo/Title -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Text text="🌍" style="-fx-fill: white;">
                    <font>
                        <Font size="28.0"/>
                    </font>
                </Text>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="ViaNova" style="-fx-fill: white;">
                    <font>
                        <Font name="Montserrat Bold" size="22.0"/>
                    </font>
                </Text>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Navigation Menu -->
            <HBox alignment="CENTER" spacing="35.0">
                <children>
                    <Label text="HOME" textFill="white" styleClass="nav-link-active"
                           style="-fx-cursor: hand; -fx-font-weight: bold;">
                        <font>
                            <Font name="Montserrat Bold" size="12.0"/>
                        </font>
                    </Label>
                    <Label text="BLOG" textFill="#FF6B6B" styleClass="nav-link-active"
                           style="-fx-cursor: hand; -fx-font-weight: bold;">
                        <font>
                            <Font name="Montserrat Bold" size="12.0"/>
                        </font>
                    </Label>
                    <Label text="DESTINATIONS" textFill="#cccccc" styleClass="nav-link"
                           style="-fx-cursor: hand;">
                        <font>
                            <Font name="Montserrat Regular" size="12.0"/>
                        </font>
                    </Label>
                    <Label text="ABOUT" textFill="#cccccc" styleClass="nav-link"
                           style="-fx-cursor: hand;">
                        <font>
                            <Font name="Montserrat Regular" size="12.0"/>
                        </font>
                    </Label>
                    <Label text="CONTACT" textFill="#cccccc" styleClass="nav-link"
                           style="-fx-cursor: hand;">
                        <font>
                            <Font name="Montserrat Regular" size="12.0"/>
                        </font>
                    </Label>
                </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Search Icon -->
            <Label text="🔍" textFill="white" style="-fx-cursor: hand;">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>
        </children>
    </HBox>

    <!-- Main Content -->
    <ScrollPane fitToWidth="true" prefHeight="680.0" prefWidth="1366.0"
                style="-fx-background-color: white; -fx-border-color: transparent;">
        <content>
            <VBox prefWidth="1366.0">
                <children>
                    <!-- Hero Section with Image -->
                    <StackPane prefHeight="400.0" prefWidth="1366.0">
                        <children>
                            <!-- Background Image -->
                            <ImageView fitHeight="400.0" fitWidth="1366.0" preserveRatio="false">
                                <image>
                                    <Image url="@../img/hero-blog.jpg"/>
                                </image>
                            </ImageView>

                            <!-- Dark Overlay -->
                            <Pane prefHeight="400.0" prefWidth="1366.0"
                                  style="-fx-background-color: rgba(0, 0, 0, 0.4);"/>

                            <!-- Hero Text -->
                            <VBox alignment="CENTER" spacing="15.0">
                                <children>
                                    <Text strokeType="OUTSIDE" strokeWidth="0.0"
                                          text="BLOG" textAlignment="CENTER"
                                          style="-fx-fill: white; -fx-font-weight: bold;">
                                        <font>
                                            <Font name="Montserrat Bold" size="60.0"/>
                                        </font>
                                    </Text>
                                    <Text fill="white" strokeType="OUTSIDE" strokeWidth="0.0"
                                          text="Recent travel blog posts"
                                          textAlignment="CENTER">
                                        <font>
                                            <Font name="Montserrat Regular" size="20.0"/>
                                        </font>
                                    </Text>
                                </children>
                            </VBox>
                        </children>
                    </StackPane>

                    <!-- Wavy Separator (SVG Effect Simulation) -->
                    <Pane prefHeight="60.0" prefWidth="1366.0"
                          style="-fx-background-color: white;"/>

                    <!-- Blog Posts Section -->
                    <VBox alignment="TOP_CENTER" spacing="40.0"
                          style="-fx-background-color: white;">
                        <padding>
                            <Insets bottom="80.0" left="100.0" right="100.0" top="60.0"/>
                        </padding>
                        <children>
                            <!-- Section Title -->
                            <HBox alignment="CENTER_LEFT" prefWidth="1166.0">
                                <children>
                                    <VBox spacing="5.0">
                                        <children>
                                            <Text strokeType="OUTSIDE" strokeWidth="0.0"
                                                  text="BLOG POSTS" style="-fx-fill: #333333;">
                                                <font>
                                                    <Font name="Montserrat Bold" size="28.0"/>
                                                </font>
                                            </Text>
                                            <Rectangle width="80.0" height="3.0"
                                                       style="-fx-fill: #FF6B6B;"/>
                                        </children>
                                    </VBox>

                                    <Region HBox.hgrow="ALWAYS"/>

                                    <!-- Search Bar -->
                                    <TextField fx:id="searchInput"
                                               promptText="🔍 Rechercher..."
                                               prefWidth="300.0"
                                               style="-fx-background-color: #f5f5f5; -fx-background-radius: 25px; -fx-padding: 12px 25px; -fx-border-color: transparent;">
                                        <font>
                                            <Font name="Montserrat Regular" size="13.0"/>
                                        </font>
                                    </TextField>
                                </children>
                            </HBox>

                            <!-- Blog Grid (Centered, 3 columns) -->
                            <GridPane fx:id="blogGridContainer"
                                      hgap="30.0" vgap="40.0"
                                      alignment="CENTER">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="350.0" prefWidth="350.0"/>
                                    <ColumnConstraints minWidth="350.0" prefWidth="350.0"/>
                                    <ColumnConstraints minWidth="350.0" prefWidth="350.0"/>
                                </columnConstraints>
                            </GridPane>
                        </children>
                    </VBox>
                </children>
            </VBox>
        </content>
    </ScrollPane>
</VBox>