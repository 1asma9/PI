<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" prefHeight="490.0" prefWidth="360.0"
      styleClass="blog-card"
      stylesheets="@../css/FrontendBlogStyle.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a8.controllers.FrontendBlogCardController"
      onMouseClicked="#openBlogDetail"
      onMouseEntered="#onMouseEntered"
      onMouseExited="#onMouseExited">
    <children>
        <StackPane prefHeight="232.0" prefWidth="360.0" styleClass="blog-card-image-wrap">
            <children>
                <ImageView fx:id="blogImage" fitHeight="232.0" fitWidth="360.0"
                           preserveRatio="false">
                    <image>
                        <Image url="@../img/default-blog.png"/>
                    </image>
                </ImageView>
                <Pane fx:id="imageOverlay"
                      prefHeight="232.0" prefWidth="360.0"
                      style="-fx-background-color: transparent;"
                      mouseTransparent="true"/>
            </children>
        </StackPane>

        <VBox prefHeight="258.0" prefWidth="360.0" styleClass="blog-card-content">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <children>
                <Label text="Feature Story" styleClass="chip"/>

                <Text fx:id="blogTitle"
                      text="Blog title"
                      wrappingWidth="320.0"
                      styleClass="card-title"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <HBox fx:id="starsContainer" spacing="2">
                        <Text text="*****" style="-fx-fill: #FFD700; -fx-font-size: 14px;"/>
                    </HBox>
                    <Label fx:id="ratingLabel" text="4.5" styleClass="rating-number"/>
                    <Label fx:id="reviewCountLabel" text="(23)" styleClass="rating-count"/>
                </HBox>

                <Text fx:id="blogExcerpt"
                      text="Preview content..."
                      wrappingWidth="320.0"
                      styleClass="card-excerpt"/>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT">
                    <children>
                        <HBox alignment="CENTER" spacing="5" styleClass="read-pill">
                            <Label text="READ ARTICLE" styleClass="read-pill-text"/>
                            <Label text=">" styleClass="read-pill-text"/>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="blogDate" text="February 26, 2026" styleClass="card-date"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
