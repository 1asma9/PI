<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.*?>

<Pane fx:id="content_area"
      prefHeight="629.0"
      prefWidth="1084.0"
      style="-fx-background-color: #f5efe6;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a8.controllers.BlogListController">

    <children>

        <!-- ================= HEADER ================= -->
        <HBox alignment="CENTER_LEFT"
              layoutX="30.0"
              layoutY="25.0"
              spacing="20">

            <Text text="Liste des Blogs"
                  fill="#6b4f3b"
                  style="-fx-font-size: 26px; -fx-font-weight: bold;" />

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="blogSearchInput"
                       prefWidth="250"
                       promptText="Rechercher..."
                       style="-fx-background-color: white;
                              -fx-background-radius: 20;
                              -fx-border-radius: 20;
                              -fx-border-color: #d2b48c;
                              -fx-padding: 6 15;" />

            <ComboBox fx:id="sortComboBox"
                      prefWidth="150"
                      promptText="Trier par"
                      style="-fx-background-radius: 20;
                             -fx-border-radius: 20;" />

            <Button fx:id="addBlogBtn"
                    text="+ Ajouter"
                    onMouseClicked="#openAddBlogForm"
                    style="-fx-background-color: #c8a27c;
                           -fx-text-fill: white;
                           -fx-background-radius: 20;
                           -fx-padding: 6 18;" />
        </HBox>

        <!-- ================= BLOG GRID ================= -->
        <ScrollPane layoutX="30.0"
                    layoutY="110.0"
                    prefHeight="480.0"
                    prefWidth="1024.0"
                    style="-fx-background-color: transparent;">

            <content>
                <GridPane fx:id="BlogListContainer"
                          alignment="TOP_LEFT"
                          hgap="20.0"
                          vgap="20.0">

                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20"/>
                    </padding>

                    <columnConstraints>
                        <ColumnConstraints prefWidth="300"/>
                        <ColumnConstraints prefWidth="300"/>
                        <ColumnConstraints prefWidth="300"/>
                    </columnConstraints>

                </GridPane>
            </content>
        </ScrollPane>

        <!-- ================= ADD / EDIT MODAL ================= -->
        <HBox fx:id="blogFormModal"
              alignment="CENTER"
              prefHeight="700"
              prefWidth="1366"
              style="-fx-background-color: rgba(0,0,0,0.4);"
              visible="false">

            <children>

                <Pane prefHeight="550"
                      prefWidth="600"
                      style="-fx-background-color: #fffaf3;
                             -fx-background-radius: 20;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 20, 0, 0, 6);">

                    <children>

                        <!-- Modal Header -->
                        <HBox alignment="CENTER_LEFT"
                              prefHeight="60"
                              prefWidth="600"
                              style="-fx-background-color: #c8a27c;
                                     -fx-background-radius: 20 20 0 0;">

                            <padding>
                                <Insets left="25"/>
                            </padding>

                            <children>

                                <Text fx:id="modalTitle"
                                      text="Ajouter un Blog"
                                      fill="white"
                                      style="-fx-font-size: 20px; -fx-font-weight: bold;" />

                                <Region HBox.hgrow="ALWAYS"/>

                                <Text text="✕"
                                      fill="white"
                                      onMouseClicked="#closeBlogFormModal"
                                      style="-fx-font-size: 20px; -fx-cursor: hand;" />
                            </children>
                        </HBox>

                        <!-- Form Content -->
                        <ScrollPane layoutY="60"
                                    prefHeight="430"
                                    prefWidth="600"
                                    style="-fx-background-color: transparent;">

                            <content>
                                <VBox spacing="15">

                                    <padding>
                                        <Insets top="20" left="30" right="30" bottom="20"/>
                                    </padding>

                                    <!-- Titre -->
                                    <TextField fx:id="titreInput"
                                               promptText="Titre du blog"
                                               style="-fx-background-radius: 10;" />

                                    <!-- Slug -->
                                    <TextField fx:id="slugInput"
                                               promptText="Slug"
                                               style="-fx-background-radius: 10;" />

                                    <!-- Extrait -->
                                    <TextArea fx:id="extraitInput"
                                              promptText="Résumé du blog"
                                              prefHeight="80"
                                              wrapText="true"
                                              style="-fx-background-radius: 10;" />

                                    <!-- Contenu -->
                                    <TextArea fx:id="contenuInput"
                                              promptText="Contenu complet"
                                              prefHeight="150"
                                              wrapText="true"
                                              style="-fx-background-radius: 10;" />

                                    <!-- Image -->
                                    <TextField fx:id="imageCouvertureInput"
                                               promptText="URL de l'image"
                                               style="-fx-background-radius: 10;" />

                                    <!-- Status -->
                                    <CheckBox fx:id="statusCheckbox"
                                              text="Publié" />

                                </VBox>
                            </content>
                        </ScrollPane>

                        <!-- Buttons -->
                        <HBox alignment="CENTER"
                              layoutY="500"
                              prefHeight="50"
                              prefWidth="600"
                              spacing="20">

                            <Button text="Annuler"
                                    onMouseClicked="#closeBlogFormModal"
                                    style="-fx-background-color: transparent;
                                           -fx-border-color: #c8a27c;
                                           -fx-border-radius: 20;
                                           -fx-text-fill: #6b4f3b;" />

                            <Button text="Enregistrer"
                                    onMouseClicked="#saveBlog"
                                    style="-fx-background-color: #c8a27c;
                                           -fx-text-fill: white;
                                           -fx-background-radius: 20;" />
                        </HBox>

                    </children>
                </Pane>

            </children>
        </HBox>

        <!-- ================= DELETE MODAL ================= -->
        <HBox fx:id="deleteConfirmModal"
              alignment="CENTER"
              prefHeight="700"
              prefWidth="1366"
              style="-fx-background-color: rgba(0,0,0,0.4);"
              visible="false">

            <children>

                <Pane prefHeight="220"
                      prefWidth="400"
                      style="-fx-background-color: #fffaf3;
                             -fx-background-radius: 20;">

                    <children>

                        <VBox alignment="CENTER"
                              spacing="20"
                              prefHeight="220"
                              prefWidth="400">

                            <Text text="Voulez-vous vraiment supprimer ce blog ?"
                                  wrappingWidth="320"
                                  textAlignment="CENTER"
                                  fill="#6b4f3b"
                                  style="-fx-font-size: 14px;" />

                            <HBox spacing="20">

                                <Button text="Annuler"
                                        onMouseClicked="#closeDeleteConfirmModal"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: #c8a27c;
                                               -fx-border-radius: 20;
                                               -fx-text-fill: #6b4f3b;" />

                                <Button text="Supprimer"
                                        onMouseClicked="#confirmDelete"
                                        style="-fx-background-color: #a47148;
                                               -fx-text-fill: white;
                                               -fx-background-radius: 20;" />
                            </HBox>

                        </VBox>
                    </children>
                </Pane>

            </children>
        </HBox>

    </children>
</Pane>