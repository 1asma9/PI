<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<Pane prefHeight="629.0"
      prefWidth="1084.0"
      style="-fx-background-color: #f5efe6;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a8.controllers.BlogDetailController">

    <children>

        <ScrollPane prefHeight="629.0"
                    prefWidth="1084.0"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">

            <content>

                <VBox prefWidth="1050.0" spacing="25.0">
                    <padding>
                        <Insets top="30" left="30" right="30" bottom="30"/>
                    </padding>

                    <!-- ================= BACK BUTTON ================= -->
                    <HBox alignment="CENTER_LEFT">
                        <Button fx:id="backBtn"
                                text="← Retour"
                                onAction="#goBack"
                                style="-fx-background-color: #e6d5c3;
                                       -fx-background-radius: 20;
                                       -fx-text-fill: #6b4f3b;
                                       -fx-padding: 6 18;" />
                    </HBox>

                    <!-- ================= BLOG HEADER CARD ================= -->
                    <VBox spacing="18"
                          style="-fx-background-color: #fffaf3;
                                 -fx-background-radius: 20;
                                 -fx-padding: 30;
                                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 20, 0, 0, 5);">

                        <!-- Title -->
                        <Text fx:id="blogTitle"
                              text="Titre du Blog"
                              wrappingWidth="990"
                              fill="#4e3b2a"
                              style="-fx-font-size: 28px; -fx-font-weight: bold;" />

                        <!-- Translation -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Traduire en :" textFill="#6b4f3b"/>

                            <ComboBox fx:id="languageComboBox"
                                      prefWidth="170"
                                      style="-fx-background-radius: 20;" >
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Français (FR)"/>
                                        <String fx:value="English (EN)"/>
                                        <String fx:value="Español (ES)"/>
                                        <String fx:value="العربية (AR)"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>

                            <Button fx:id="translateBtn"
                                    text="Traduire"
                                    onAction="#handleTranslate"
                                    style="-fx-background-color: #c8a27c;
                                           -fx-text-fill: white;
                                           -fx-background-radius: 20;" />

                            <Button fx:id="resetBtn"
                                    text="Version originale"
                                    onAction="#resetTranslation"
                                    style="-fx-background-color: transparent;
                                           -fx-border-color: #c8a27c;
                                           -fx-border-radius: 20;
                                           -fx-text-fill: #6b4f3b;" />
                        </HBox>

                        <!-- Meta Info -->
                        <HBox spacing="25">
                            <Label fx:id="blogAuthor"
                                   text="Par Admin"
                                   textFill="#7a6a5a"/>

                            <Label fx:id="blogDate"
                                   text="27 Déc 2025"
                                   textFill="#7a6a5a"/>

                            <Label fx:id="blogStatus"
                                   text="● Publié"
                                   textFill="#4CAF50"
                                   style="-fx-font-weight: bold;" />
                        </HBox>

                        <!-- Image -->
                        <ImageView fx:id="blogCoverImage"
                                   fitHeight="400"
                                   fitWidth="990"
                                   preserveRatio="true"
                                   style="-fx-background-radius: 15;" />

                        <!-- Excerpt -->
                        <Text fx:id="blogExcerpt"
                              wrappingWidth="990"
                              fill="#7a6a5a"
                              style="-fx-font-size: 16px; -fx-font-style: italic;" />

                        <!-- Content -->
                        <Text fx:id="blogContent"
                              wrappingWidth="990"
                              fill="#4e3b2a"
                              style="-fx-font-size: 15px;" />
                    </VBox>

                    <!-- ================= COMMENTS CARD ================= -->
                    <VBox spacing="20"
                          style="-fx-background-color: #fffaf3;
                                 -fx-background-radius: 20;
                                 -fx-padding: 30;
                                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 20, 0, 0, 5);">

                        <!-- Header -->
                        <HBox spacing="10">
                            <Text text="💬 Commentaires"
                                  fill="#4e3b2a"
                                  style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                            <Label fx:id="commentCountLabel"
                                   text="(0)"
                                   textFill="#a1887f"/>
                        </HBox>

                        <Separator/>

                        <!-- Add Comment -->
                        <VBox spacing="15">

                            <Label text="Ajouter un commentaire"
                                   textFill="#6b4f3b"
                                   style="-fx-font-weight: bold;" />

                            <HBox spacing="15">
                                <TextField fx:id="commentUserInput"
                                           promptText="Votre nom"
                                           prefWidth="200"
                                           style="-fx-background-radius: 10;" />

                                <TextField fx:id="commentImageInput"
                                           promptText="URL de votre photo (optionnel)"
                                           prefWidth="300"
                                           style="-fx-background-radius: 10;" />
                            </HBox>

                            <TextArea fx:id="commentContentInput"
                                      prefHeight="100"
                                      wrapText="true"
                                      promptText="Écrivez votre commentaire..."
                                      style="-fx-background-radius: 10;" />

                            <HBox alignment="CENTER_RIGHT">
                                <Button fx:id="submitCommentBtn"
                                        text="Publier"
                                        onAction="#submitComment"
                                        style="-fx-background-color: #c8a27c;
                                               -fx-text-fill: white;
                                               -fx-background-radius: 20;
                                               -fx-padding: 6 18;" />
                            </HBox>
                        </VBox>

                        <Separator/>

                        <!-- Comments List -->
                        <VBox fx:id="commentsContainer"
                              spacing="15"/>

                        <!-- Empty State -->
                        <VBox fx:id="emptyCommentsState"
                              alignment="CENTER"
                              spacing="8"
                              visible="false">
                            <Text text="Aucun commentaire pour le moment"
                                  fill="#a1887f"/>
                            <Text text="Soyez le premier à commenter !"
                                  fill="#a1887f"/>
                        </VBox>

                    </VBox>

                </VBox>

            </content>
        </ScrollPane>

    </children>
</Pane>