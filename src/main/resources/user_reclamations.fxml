<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="900.0" 
            styleClass="page"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controllers.UserReclamationsController">
   
   <!-- Top Bar -->
   <top>
      <VBox>
         <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="15">
            <Button text="← Retour" styleClass="btnOutline" onAction="#retourMenu" />
            <Label fx:id="lblPageTitle" text="MES RÉCLAMATIONS" styleClass="pageTitle" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnAdd" text="+ Ajouter" styleClass="btnGold" onAction="#ajouterReclamation" />
         </HBox>
      </VBox>
   </top>
   
   <!-- Center Content -->
   <center>
      <VBox styleClass="pageContent" spacing="20">
         
         <!-- Search and Filter (Simplified for now to match controller) -->
         <HBox spacing="15" alignment="CENTER_LEFT" styleClass="card">
            <!-- Champ de recherche -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
               <Label text="Rechercher :" styleClass="metaText" />
               <TextField fx:id="txtRecherche" 
                          promptText="Rechercher par titre ou description..." 
                          prefWidth="300" onKeyReleased="#appliquerFiltres" />
            </VBox>
            
            <!-- Filtre par statut -->
            <VBox spacing="5">
               <Label text="Statut :" styleClass="metaText" />
               <ComboBox fx:id="comboStatut" prefWidth="150" promptText="Tous" onAction="#appliquerFiltres" />
            </VBox>
            
            <!-- Bouton rechercher -->
            <Button text="🔍 Rechercher" 
                    styleClass="btnGold" 
                    onAction="#appliquerFiltres" />
            
            <!-- Bouton réinitialiser -->
            <Button text="↻ Réinitialiser" 
                    styleClass="btnOutline" 
                    onAction="#reinitialiser" />
         </HBox>
         
         <!-- Table -->
         <TableView fx:id="tableReclamations" styleClass="table-view" VBox.vgrow="ALWAYS">
            <columns>
               <TableColumn fx:id="colTitre" text="Titre" prefWidth="200" />
               <TableColumn fx:id="colDescription" text="Description" prefWidth="300" />
               <TableColumn fx:id="colStatut" text="Statut" prefWidth="120" />
                <TableColumn fx:id="colDate" text="Date" prefWidth="150" />
                <TableColumn fx:id="colDateReponse" text="Date réponse" prefWidth="150" />
                <TableColumn fx:id="colActions" text="Actions" prefWidth="100" />
            </columns>
         </TableView>
         
      </VBox>
   </center>
   
</BorderPane>
